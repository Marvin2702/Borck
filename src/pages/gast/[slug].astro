---
// =========================================================================
// Dauerhafte Brücke für spätere Wohnungs-QR-Codes. Solange der kombinierte
// App-Build nicht ausdrücklich aktiviert ist, verspricht sie weder eine App
// noch eine Web-Vorschau. Die interne Seite bleibt immer noindex.
// =========================================================================
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { withBase } from '../../i18n/utils';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const apartments = await getCollection('apartments');
  return apartments.map((a) => ({ params: { slug: a.id }, props: { name: a.data.name, accent: a.data.accent } }));
}

const { name, accent } = Astro.props;
const { slug } = Astro.params;
const appLink = `hausaquamarin://wohnung/${slug}`;
const guestAppEnabled = site.guestAppEnabled;
---
<BaseLayout
  title={`Gäste-Info ${name} · ${site.name}`}
  description={`Gäste-Infos für die Ferienwohnung ${name} im ${site.name} Büsum.`}
  pageKey={`gast/${slug}`}
  noindex={true}
  noAlternates={true}
>
  <section class="section">
    <div class="container-narrow gast" style={`--a:${accent}`}>
      <p class="eyebrow">Moin in {name}!</p>
      <h1>{guestAppEnabled ? 'Deine Gäste-App' : 'Infos für deinen Aufenthalt'}</h1>
      {guestAppEnabled ? (
        <p class="lead">
          Check-in, Gästemappe, Ausflugstipps und Ebbe &amp; Flut — praktisch gebündelt für deinen Aufenthalt.
        </p>
      ) : (
        <p class="lead">
          Die digitale Gästemappe wird noch vorbereitet. Bis zur Freigabe findest du alle wichtigen Hinweise direkt
          in der Wohnung — bei Fragen sind wir persönlich für dich da.
        </p>
      )}

      <div class="gast-actions">
        {guestAppEnabled && (
          <>
            <a class="btn btn--gold btn--lg" href={appLink}>Gäste-App öffnen</a>
            <a class="btn btn--ghost" href={withBase('gast-app/')}>App im Browser ansehen</a>
            <p class="gast-hint">
              Wenn die App auf diesem Gerät nicht installiert ist, kannst du die Web-Vorschau nutzen. Die Hinweise in
              der Wohnung und unser direkter Kontakt bleiben ebenfalls verfügbar.
            </p>
          </>
        )}
        <div class="gast-contact">
          <a class="btn btn--ghost" href={`tel:${site.phone.replace(/\s/g, '')}`}><Icon name="phone" size={16} /> {site.phoneDisplay}</a>
          <a class="btn btn--ghost" href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"><Icon name="chat" size={16} /> WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gast h1 { color: color-mix(in srgb, var(--a) 70%, black); }
  .gast-actions { display: grid; gap: 1rem; justify-items: start; margin-top: 1.5rem; }
  .gast-hint { color: var(--text-muted); max-width: 48ch; margin: 0; }
  .gast-contact { display: flex; gap: 0.7rem; flex-wrap: wrap; }
</style>
