---
import { render, getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from './BookingWidget.astro';
import GoodToKnow from './GoodToKnow.astro';
import Img from './Img.astro';
import Icon from './Icon.astro';
import { useTranslations, localizedPath, withBase, withoutBase, type Lang } from '../i18n/utils';
import { priceFrom } from '../data/prices';
import { trApt, trFeature } from '../data/apartments-i18n';
import { site } from '../data/site';
import { galleryImageAlt } from '../data/gallery-alt';

interface Props { lang: Lang; apartment: CollectionEntry<'apartments'> }
const { lang, apartment } = Astro.props;
const t = useTranslations(lang);
const d = apartment.data;
const { Content } = await render(apartment);

const origin = new URL(site.domain);
const detailUrl = new URL(withoutBase(localizedPath(`apartments/${apartment.id}`, lang)), origin).href;
const price = priceFrom(d.smoobu_id, d.price_from);
// 1-Klick-Buchung: direkt zur Smoobu-Buchungsseite dieses Apartments.
const bookUrl = d.smoobu_id ? `${site.smoobuBookingPage}?apartmentId=${d.smoobu_id}` : '#buchung';

const tr = trApt(apartment.id, lang);
const view = tr?.view ?? d.view;
const summary = tr?.summary ?? d.summary;
const apt = t('apartments.holidayApt');
// Ortspräposition lokalisiert (DA: "i Büsum", sonst "in Büsum").
const inTown = lang === 'da' ? 'i Büsum' : 'in Büsum';
const lightboxUi: Record<Lang, { enlarge: string; gallery: string; close: string; prev: string; next: string }> = {
  de: { enlarge: 'vergrößern', gallery: 'Bildergalerie', close: 'Schließen', prev: 'Vorheriges Bild', next: 'Nächstes Bild' },
  en: { enlarge: 'enlarge', gallery: 'Image gallery', close: 'Close', prev: 'Previous image', next: 'Next image' },
  nl: { enlarge: 'vergroten', gallery: 'Fotogalerij', close: 'Sluiten', prev: 'Vorige afbeelding', next: 'Volgende afbeelding' },
  da: { enlarge: 'forstør', gallery: 'Billedgalleri', close: 'Luk', prev: 'Forrige billede', next: 'Næste billede' },
};
const lbu = lightboxUi[lang];

const title = `${apt} ${d.name} · ${site.name} Büsum`;
const description = `${apt} ${d.name} ${inTown}: ${summary} ${d.persons} ${t('apartments.persons')}, ${view}.`;

// JSON-LD: Apartment (+ Ab-Preis, falls vorhanden). Der statische Build kennt
// keine datumsbezogene Verfügbarkeit und behauptet deshalb bewusst kein InStock.
const apartmentLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Apartment',
  name: `${site.name} · ${d.name}`,
  description: summary,
  url: detailUrl,
  containedInPlace: { '@id': new URL(withoutBase(withBase('#lodging')), origin).href },
  image: d.gallery.map((g) => new URL(withoutBase(withBase(g)), origin).href),
  occupancy: { '@type': 'QuantitativeValue', maxValue: d.persons },
  numberOfBedrooms: d.bedrooms,
  petsAllowed: d.dogFriendly,
  checkinTime: site.checkinTime,
  checkoutTime: site.checkoutTime,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  ...(d.size_qm
    ? { floorSize: { '@type': 'QuantitativeValue', value: d.size_qm, unitCode: 'MTK' } }
    : {}),
  amenityFeature: d.features.map((f) => ({ '@type': 'LocationFeatureSpecification', name: trFeature(f, lang) })),
  ...(price
    ? {
        offers: {
          '@type': 'AggregateOffer',
          lowPrice: price,
          priceCurrency: 'EUR',
          url: d.smoobu_id ? bookUrl : detailUrl,
        },
      }
    : {}),
};

// Breadcrumb (Start › Apartments › {Name}) für die SERP-Darstellung.
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home'), item: new URL(withoutBase(localizedPath('', lang)), origin).href },
    { '@type': 'ListItem', position: 2, name: t('apartments.title'), item: new URL(withoutBase(localizedPath('apartments', lang)), origin).href },
    { '@type': 'ListItem', position: 3, name: d.name, item: detailUrl },
  ],
};

// Interne Verlinkung: bis zu 3 weitere Apartments (nach Reihenfolge).
const others = (await getCollection('apartments'))
  .filter((a) => a.id !== apartment.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---
<BaseLayout
  title={title}
  description={description}
  pageKey={`apartments/${apartment.id}`}
  image={d.heroImage}
  jsonLd={[apartmentLd, breadcrumbLd]}
>
  <article data-apartment-detail data-apartment-id={apartment.id}>
    <header class="apt-hero" style={`--a:${d.accent}`}>
      <div class="container apt-hero-inner">
        <a class="back" href={localizedPath('apartments', lang)}>← {t('apartments.title')}</a>
        <p class="eyebrow">{view}</p>
        <h1>{d.name}</h1>
        <p class="lead">{summary}</p>
        <ul class="apt-facts">
          <li><strong>{d.persons}</strong> {t('apartments.persons')}</li>
          {d.bedrooms && <li><strong>{d.bedrooms}</strong> {d.bedrooms === 1 ? t('apartments.bedroom') : t('apartments.bedrooms')}</li>}
          {d.size_qm && <li><strong>{d.size_qm}</strong> m²</li>}
          {price && <li>{t('apartments.from')} <strong>{price} €</strong>/{t('apartments.night')}</li>}
        </ul>
      </div>
    </header>

    {d.gallery.length > 0 && (
      <section class="apt-gallery-sec">
        <div class="container">
          <div class={`apt-gallery ${d.gallery.length > 3 ? 'count-many' : `count-${d.gallery.length}`}`}>
            {d.gallery.map((src, i) => (
              <figure class={i === 0 ? 'g-main' : ''} data-lightbox-item role="button" tabindex="0" aria-label={`${galleryImageAlt(src, d.name, lang, view)} – ${lbu.enlarge}`}>
                <Img src={src} alt={galleryImageAlt(src, d.name, lang, view)}
                     width={1200} height={800}
                     loading={i === 0 ? 'eager' : 'lazy'}
                     fetchpriority={i === 0 ? 'high' : undefined}
                     widths={i === 0 ? [640, 768, 1024, 1600] : undefined}
                     decoding={i === 0 ? 'sync' : 'async'}
                     defer={i > 0}
                     sizes="(max-width: 820px) 100vw, 66vw" />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <BookingWidget lang={lang} smoobuId={d.smoobu_id} apartmentName={d.name} />

    <section class="section">
      <div class="container detail-grid">
        <div class="detail-body">
          {tr?.description ? <p>{tr.description}</p> : <Content />}
        </div>
        <aside class="detail-aside">
          <h2 class="aside-title">{t('apartments.features')}</h2>
          <ul class="feature-list">
            {d.features.map((f) => <li><Icon name="check" size={16} class="feat-ic" /> {trFeature(f, lang)}</li>)}
          </ul>
          {d.dogFriendly && <p class="dog-badge"><Icon name="paw" size={16} /> {t('usp.pets.title')}</p>}
          <a href="#buchung" class="btn btn--gold" data-track-apartment={apartment.id} data-track-location="detail_aside" style="margin-top:1rem;width:100%;justify-content:center">
            {t('cta.bookNow')}
          </a>
        </aside>
      </div>
    </section>

    <GoodToKnow lang={lang} />

    <section class="section section--alt more-sec">
      <div class="container">
        <h2>{t('apartments.more')}</h2>
        <div class="more-grid">
          {others.map((o) => (
            <a class="more-card" href={localizedPath(`apartments/${o.id}`, lang)}>
              {o.data.heroImage && (
                <span class="more-thumb">
                  <Img src={o.data.heroImage} alt="" width={128} height={96} loading="lazy" sizes="64px" />
                </span>
              )}
              <span class="more-txt">
                <strong>{o.data.name}</strong>
                <span>{trApt(o.id, lang)?.view ?? o.data.view}</span>
              </span>
            </a>
          ))}
        </div>
        <p class="more-lage">{t('apartments.exploreArea')} <a href={localizedPath('lage', lang)}>{t('nav.location')} →</a></p>
      </div>
    </section>

    <div class="sticky-cta">
      <span class="sticky-price">
        {price ? <span>{t('apartments.from')} <strong>{price} €</strong></span> : <strong>{d.name}</strong>}
      </span>
      {/* Zum Kalender auf der Seite statt externem Smoobu-Absprung — der Anker-
          Scroll lädt das Widget über dessen IntersectionObserver gleich mit. */}
      <a href="#buchung" class="btn btn--gold" data-track-apartment={apartment.id} data-track-location="sticky_cta">{t('nav.book')}</a>
    </div>

    <div class="lightbox" data-lightbox role="dialog" aria-modal="true" aria-label={lbu.gallery} hidden>
      <button class="lightbox-close" type="button" aria-label={lbu.close} data-lightbox-close>×</button>
      <button class="lightbox-nav lightbox-prev" type="button" aria-label={lbu.prev} data-lightbox-prev>‹</button>
      <figure class="lightbox-figure">
        <img class="lightbox-img" alt="" />
        <figcaption class="lightbox-caption">
          <span data-lightbox-text></span>
          <span class="lightbox-count" aria-live="polite" data-lightbox-count></span>
        </figcaption>
      </figure>
      <button class="lightbox-nav lightbox-next" type="button" aria-label={lbu.next} data-lightbox-next>›</button>
    </div>
  </article>
</BaseLayout>

<style>
  .apt-hero { background: linear-gradient(150deg, color-mix(in srgb, var(--a) 22%, white), var(--c-sand-50)); border-bottom: 1px solid var(--line); }
  .apt-hero-inner { padding-block: clamp(1.2rem, 0.8rem + 1.6vw, 2.2rem) clamp(2rem, 1.2rem + 4vw, 4rem); }
  .apt-hero h1 { color: color-mix(in srgb, var(--a) 70%, black); }
  .apt-hero .eyebrow { color: color-mix(in srgb, var(--a) 65%, black); }
  .apt-hero .lead { color: var(--c-ink-700); } /* AA-Kontrast auf getöntem Hero */
  .back { display: inline-block; margin-bottom: 1rem; text-decoration: none; font-weight: 600; color: var(--brand); }
  .apt-facts { list-style: none; display: flex; flex-wrap: wrap; gap: 0.6rem 1.6rem; padding: 0; margin: 1.2rem 0 0; color: var(--text-muted); }
  .apt-facts strong { color: var(--text); }
  .detail-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2.5rem; align-items: start; }
  .detail-body { font-size: 1.05rem; max-width: 65ch; hyphens: auto; }
  .detail-aside { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); position: sticky; top: 90px; }
  /* Unterhalb ~1.4rem wirkt die Serif stumpf — kleine Titel in der Grotesk. */
  .aside-title { font-family: var(--font-body); font-weight: 650; font-size: 1.05rem; margin-top: 0; }
  .feature-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.55rem; }
  .feature-list li { color: var(--text); display: flex; gap: 0.5rem; align-items: baseline; }
  .feature-list li :global(.feat-ic) { flex: none; color: var(--c-deich-700); transform: translateY(2px); }
  .dog-badge { margin-top: 1rem; color: var(--brand); font-weight: 600; display: inline-flex; align-items: center; gap: 0.45rem; }
  @media (max-width: 820px) { .detail-grid { grid-template-columns: 1fr; } .detail-aside { position: static; } }

  .apt-gallery-sec { padding-top: clamp(1.5rem, 1rem + 2vw, 2.5rem); }
  .apt-gallery { display: grid; gap: 0.8rem; }
  .apt-gallery figure { margin: 0; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); height: clamp(300px, 34vw, 460px); outline: 0; cursor: zoom-in; }
  .apt-gallery figure:focus-visible { box-shadow: 0 0 0 4px var(--c-aqua-300), var(--shadow-md); }
  /* :global nötig: die <img> stammen aus der Kind-Komponente Img.astro und tragen
     die Scope-Klasse dieser Komponente nicht — gescopte img-Selektoren greifen nie. */
  .apt-gallery figure :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .apt-gallery.count-2 { grid-template-columns: 1.618fr 1fr; }
  .apt-gallery.count-3 { grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr; height: clamp(360px, 44vw, 560px); }
  .apt-gallery.count-3 figure { height: 100%; min-height: 0; }
  .apt-gallery.count-3 .g-main { grid-row: 1 / 3; }
  /* Mehr als 3 Bilder: Hauptbild 2×2, Rest im 3er-Raster */
  .apt-gallery.count-many { grid-template-columns: repeat(3, 1fr); grid-auto-rows: clamp(150px, 15vw, 220px); }
  .apt-gallery.count-many figure { height: 100%; min-height: 0; }
  .apt-gallery.count-many .g-main { grid-column: span 2; grid-row: span 2; }
  @media (max-width: 640px) {
    .apt-gallery, .apt-gallery.count-2, .apt-gallery.count-3, .apt-gallery.count-many { grid-template-columns: 1fr; grid-template-rows: none; grid-auto-rows: auto; height: auto; }
    .apt-gallery.count-3 .g-main, .apt-gallery.count-many .g-main { grid-column: auto; grid-row: auto; }
    .apt-gallery figure, .apt-gallery.count-3 figure, .apt-gallery.count-many figure { height: clamp(200px, 55vw, 300px); }
  }

  /* Galerie-Lightbox */
  .lightbox { position: fixed; inset: 0; z-index: 300; background: rgba(5, 28, 34, 0.96); display: grid; grid-template-columns: auto minmax(0, 1fr) auto; align-items: center; gap: 1rem; padding: 1.5rem; }
  .lightbox[hidden] { display: none; }
  .lightbox-figure { min-width: 0; margin: 0; display: grid; justify-items: center; gap: .8rem; }
  .lightbox-img { max-width: 100%; max-height: 82vh; object-fit: contain; border-radius: 8px; box-shadow: var(--shadow-lg); touch-action: pan-y; }
  .lightbox-caption { width: min(100%, 900px); display: flex; justify-content: space-between; gap: 1rem; color: rgba(255,255,255,.82); font-size: .9rem; }
  .lightbox-count { white-space: nowrap; color: #f5d887; font-weight: 700; }
  .lightbox-close { position: absolute; top: 0.8rem; right: 1.2rem; background: none; border: 0; color: #fff; font-size: 2.6rem; line-height: 1; cursor: pointer; }
  .lightbox-nav { width: 48px; height: 48px; border-radius: 50%; border: 1px solid rgba(255,255,255,.34); color: #fff; background: rgba(255,255,255,.08); font-size: 2rem; cursor: pointer; }
  .lightbox-nav:hover, .lightbox-nav:focus-visible, .lightbox-close:focus-visible { color: #082f39; background: #fff; outline: 0; }
  @media (prefers-reduced-motion: no-preference) {
    .lightbox { opacity: 1; transition: opacity 0.22s ease, display 0.22s ease allow-discrete; }
    .lightbox[hidden] { opacity: 0; }
    @starting-style { .lightbox { opacity: 0; } }
  }
  @media (max-width: 640px) {
    .lightbox { grid-template-columns: 1fr; padding: 3.5rem .7rem 1rem; }
    .lightbox-nav { position: absolute; top: 50%; z-index: 1; width: 42px; height: 42px; background: rgba(5,28,34,.72); }
    .lightbox-prev { left: .7rem; }
    .lightbox-next { right: .7rem; }
    .lightbox-caption { padding-inline: .4rem; font-size: .78rem; }
  }

  .more-sec h2 { margin-top: 0; }
  .more-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1rem 0 1.2rem; }
  .more-card { display: flex; align-items: center; gap: 0.85rem; padding: 0.8rem 1rem; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); text-decoration: none; box-shadow: var(--shadow-sm); transition: transform 0.15s ease, border-color 0.2s ease; }
  .more-card:hover { transform: translateY(-3px); border-color: var(--c-aqua-300); }
  .more-thumb { flex: none; width: 64px; height: 48px; border-radius: 8px; overflow: hidden; }
  .more-thumb :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .more-txt { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .more-card strong { color: var(--brand-strong); font-weight: 650; font-size: 1.05rem; }
  .more-card span { color: var(--text-muted); font-size: 0.9rem; }
  .more-lage a { color: var(--brand); font-weight: 600; text-decoration: none; }
  @media (max-width: 700px) { .more-grid { grid-template-columns: 1fr; } }

  /* Sticky Buchungs-CTA: mobil als Leiste, auf Desktop als Floating-Pill nach Scroll */
  /* Anker-Ziel unter dem Sticky-Header freihalten */
  :global(#buchung) { scroll-margin-top: 84px; }
  .sticky-cta {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
    display: none; align-items: center; justify-content: space-between; gap: 1rem;
    background: rgba(255, 255, 255, 0.96); backdrop-filter: blur(8px);
    border-top: 1px solid var(--line);
    padding: 0.7rem 1.1rem calc(0.7rem + env(safe-area-inset-bottom, 0px));
    box-shadow: 0 -4px 20px rgba(13, 59, 68, 0.1);
  }
  .sticky-cta .btn { min-height: 44px; white-space: nowrap; }
  .sticky-price strong { color: var(--brand-strong); font-size: 1.15rem; font-variant-numeric: tabular-nums; }
  @media (max-width: 820px) {
    .sticky-cta { display: flex; }
    article { padding-bottom: 76px; }
  }
  @media (min-width: 821px) {
    .sticky-cta {
      display: flex; left: auto; right: 1.5rem; bottom: 1.5rem;
      border: 1px solid var(--line); border-radius: 999px;
      padding: 0.55rem 0.6rem 0.55rem 1.3rem;
      box-shadow: var(--shadow-lg);
      opacity: 0; transform: translateY(120%); pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .sticky-cta.is-visible { opacity: 1; transform: none; pointer-events: auto; }
  }
</style>

<script>
  // Galerie-Lightbox
  const lb = document.querySelector<HTMLElement>('[data-lightbox]');
  const lbImg = lb?.querySelector('.lightbox-img') as HTMLImageElement | null;
  const lbText = lb?.querySelector<HTMLElement>('[data-lightbox-text]');
  const lbCount = lb?.querySelector<HTMLElement>('[data-lightbox-count]');
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-lightbox-item]'));
  let activeIndex = 0;
  let returnFocus: HTMLElement | null = null;
  let touchStartX = 0;
  const showImage = (index: number) => {
    if (!lbImg || !items.length) return;
    activeIndex = (index + items.length) % items.length;
    const img = items[activeIndex].querySelector('img') as HTMLImageElement | null;
    if (!img) return;
    lbImg.src = img.dataset.fullSrc || img.currentSrc || img.src;
    lbImg.alt = img.alt || '';
    if (lbText) lbText.textContent = img.alt || '';
    if (lbCount) lbCount.textContent = `${activeIndex + 1} / ${items.length}`;
  };
  const closeLb = () => {
    if (!lb || lb.hidden) return;
    lb.hidden = true;
    document.body.style.overflow = '';
    returnFocus?.focus();
  };
  const openLb = (index: number, trigger: HTMLElement) => {
    if (!lb) return;
    returnFocus = trigger;
    showImage(index);
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
    lb.querySelector<HTMLButtonElement>('[data-lightbox-close]')?.focus();
  };
  items.forEach((item, index) => {
    item.addEventListener('click', () => openLb(index, item));
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLb(index, item); }
    });
  });
  lb?.querySelector('[data-lightbox-prev]')?.addEventListener('click', () => showImage(activeIndex - 1));
  lb?.querySelector('[data-lightbox-next]')?.addEventListener('click', () => showImage(activeIndex + 1));
  lbImg?.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0]?.clientX ?? 0; }, { passive: true });
  lbImg?.addEventListener('touchend', (e) => {
    const delta = (e.changedTouches[0]?.clientX ?? touchStartX) - touchStartX;
    if (Math.abs(delta) > 45) showImage(activeIndex + (delta < 0 ? 1 : -1));
  }, { passive: true });
  lb?.addEventListener('click', (e) => {
    const target = e.target as Element;
    if (target === lb || target.hasAttribute('data-lightbox-close')) closeLb();
  });
  document.addEventListener('keydown', (e) => {
    if (!lb || lb.hidden) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') showImage(activeIndex - 1);
    if (e.key === 'ArrowRight') showImage(activeIndex + 1);
    if (e.key === 'Tab') {
      const focusable = Array.from(lb.querySelectorAll<HTMLElement>('button:not([disabled])'));
      if (!focusable.length) return;
      const first = focusable[0]; const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });

  // Desktop: Floating-Buchungs-CTA erst nach dem Hero einblenden (mobil ist die
  // Leiste per CSS immer sichtbar; .is-visible wirkt nur ab 821px).
  const stickyCta = document.querySelector<HTMLElement>('.sticky-cta');
  if (stickyCta) {
    const toggleCta = () => stickyCta.classList.toggle('is-visible', window.scrollY > 480);
    window.addEventListener('scroll', toggleCta, { passive: true });
    toggleCta();
  }
</script>
