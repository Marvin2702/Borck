---
import { localizedPath, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;

const txt: Record<Lang, { label: string; text: string; more: string; accept: string; decline: string }> = {
  de: { label: 'Cookie-Einwilligung', text: 'Wir nutzen Statistik-Cookies, um die Website zu verbessern. Nur mit deiner Einwilligung.', more: 'Datenschutz', accept: 'Akzeptieren', decline: 'Ablehnen' },
  en: { label: 'Cookie consent', text: 'We use statistics cookies to improve the website. Only with your consent.', more: 'Privacy', accept: 'Accept', decline: 'Decline' },
  nl: { label: 'Cookietoestemming', text: 'We gebruiken statistiek-cookies om de website te verbeteren. Alleen met je toestemming.', more: 'Privacy', accept: 'Accepteren', decline: 'Weigeren' },
  da: { label: 'Cookiesamtykke', text: 'Vi bruger statistik-cookies for at forbedre websitet. Kun med dit samtykke.', more: 'Privatliv', accept: 'Acceptér', decline: 'Afvis' },
};
const c = txt[lang];
// Rechtstexte existieren bewusst nur auf Deutsch (rechtlich verbindliches
// Original, Hinweis dazu im Footer) — daher Link auf die DE-Datenschutzseite.
const privacyHref = localizedPath('datenschutz', 'de');
---
<div class="consent" data-consent data-ga={site.googleAnalyticsId} hidden role="dialog" aria-label={c.label} tabindex="-1">
  <p>{c.text} <a href={privacyHref}>{c.more}</a></p>
  <div class="consent-actions">
    <button type="button" class="btn btn--ghost" data-consent-decline>{c.decline}</button>
    <button type="button" class="btn btn--gold" data-consent-accept>{c.accept}</button>
  </div>
</div>

<style>
  .consent {
    position: fixed; bottom: 1rem; left: 1rem; right: 1rem; z-index: 250;
    max-width: 560px; margin-inline: auto;
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
    box-shadow: var(--shadow-lg); padding: 1.1rem 1.3rem;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem 1.2rem;
  }
  .consent[hidden] { display: none; }
  .consent p { margin: 0; flex: 1 1 240px; font-size: 0.92rem; color: var(--text-muted); }
  .consent-actions { display: flex; gap: 0.6rem; }
  .consent .btn { padding: 0.55rem 1.1rem; font-size: 0.9rem; }
</style>

<script>
  // Consent-Speicherung mit Versionierung: {v, ts, categories}. Ändern sich die
  // eingesetzten Dienste/Kategorien, CONSENT_VERSION erhöhen — gespeicherte
  // Entscheidungen älterer Versionen verfallen und der Banner erscheint erneut.
  const KEY = 'ha-consent';
  const LEGACY_KEY = 'ha-consent-stats'; // altes Format ('granted'/'denied')
  const CONSENT_VERSION = 1;
  type Consent = { v: number; ts: string; categories: { statistics: boolean } };

  const el = document.querySelector<HTMLElement>('[data-consent]');
  const gaId = el?.dataset.ga || '';

  function saveConsent(statistics: boolean): Consent {
    const consent: Consent = { v: CONSENT_VERSION, ts: new Date().toISOString(), categories: { statistics } };
    try { localStorage.setItem(KEY, JSON.stringify(consent)); } catch { /* Storage blockiert -> nur Session */ }
    return consent;
  }

  function readConsent(): Consent | null {
    try {
      const raw = localStorage.getItem(KEY);
      if (raw) {
        const obj = JSON.parse(raw) as Consent;
        // Versionswechsel oder kaputte Daten => erneut fragen.
        if (obj && obj.v === CONSENT_VERSION && obj.categories && typeof obj.categories.statistics === 'boolean') return obj;
        return null;
      }
      // Migration vom alten String-Format (Entscheidung bleibt erhalten).
      const legacy = localStorage.getItem(LEGACY_KEY);
      if (legacy === 'granted' || legacy === 'denied') {
        const migrated = saveConsent(legacy === 'granted');
        localStorage.removeItem(LEGACY_KEY);
        return migrated;
      }
    } catch { /* Storage blockiert -> wie "keine Entscheidung" behandeln */ }
    return null;
  }

  function loadGA() {
    const w = window as any;
    if (!gaId || w.__gaLoaded) return;
    w.__gaLoaded = true;
    const s = document.createElement('script');
    s.async = true;
    s.src = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
    document.head.appendChild(s);
    w.dataLayer = w.dataLayer || [];
    w.gtag = function () { w.dataLayer.push(arguments); };
    w.gtag('js', new Date());
    w.gtag('config', gaId, { anonymize_ip: true });
  }

  if (gaId && el) {
    const stored = readConsent();
    if (stored?.categories.statistics) loadGA();
    else if (!stored) el.hidden = false;

    el.querySelector('[data-consent-accept]')?.addEventListener('click', () => {
      saveConsent(true);
      el.hidden = true;
      loadGA();
    });
    el.querySelector('[data-consent-decline]')?.addEventListener('click', () => {
      saveConsent(false);
      el.hidden = true;
    });

    // Widerruf/Änderung jederzeit: Footer-Link "Cookie-Einstellungen" öffnet den Banner erneut
    // (DSGVO Art. 7 Abs. 3 – Widerruf so einfach wie die Erteilung).
    // Fokus in den Dialog, damit Tastatur-Nutzer direkt bei den Optionen sind.
    document.querySelectorAll<HTMLElement>('[data-consent-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        el.hidden = false;
        el.focus();
      });
    });

    // Conversion-Signale (nur wenn GA nach Einwilligung geladen wurde): Klicks auf
    // Buchung, Telefon und WhatsApp – die drei Wege, über die Buchungen entstehen.
    document.addEventListener('click', (e) => {
      const gtag = (window as any).gtag;
      if (typeof gtag !== 'function') return;
      const a = (e.target as Element | null)?.closest?.('a[href]') as HTMLAnchorElement | null;
      if (!a) return;
      const href = a.href;
      if (href.includes('booking.smoobu.com')) gtag('event', 'begin_booking', { link_url: href });
      else if (href.startsWith('tel:')) gtag('event', 'contact_phone');
      else if (href.includes('wa.me')) gtag('event', 'contact_whatsapp');
    });
  }
</script>
