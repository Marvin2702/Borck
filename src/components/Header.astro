---
import { useTranslations, localizedPath, withBase, type Lang } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { site } from '../data/site';

interface Props { lang: Lang; noAlternates?: boolean }
const { lang, noAlternates = false } = Astro.props;
const t = useTranslations(lang);

const nav = [
  { key: 'apartments', label: t('nav.apartments') },
  { key: 'lage', label: t('nav.location') },
  // Reiseführer-Cluster nur auf Deutsch (Content DE-only).
  ...(lang === 'de' ? [{ key: 'reisefuehrer', label: 'Reiseführer' }] : []),
  { key: 'ueber-uns', label: t('nav.about') },
  { key: 'kontakt', label: t('nav.contact') },
];
const home = localizedPath('', lang);
const bookHref = localizedPath('apartments', lang);
---

<header class="site-header">
  <div class="container header-inner">
    <a href={home} class="brand" aria-label={site.name}>
      <picture>
        <source srcset={withBase('/images/logo.webp')} type="image/webp" />
        <img src={withBase('/images/logo.png')} alt="" class="brand-logo" width="44" height="44" />
      </picture>
      <span class="brand-name">{site.name}</span>
    </a>

    <button type="button" class="burger" aria-label={t('nav.menu')} aria-expanded="false" aria-controls="site-nav" data-navtoggle>
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav" aria-label={t('nav.menu')}>
      {nav.map((item) => {
        const href = localizedPath(item.key, lang);
        const current = Astro.url.pathname.startsWith(href);
        return <a href={href} class="nav-link" aria-current={current ? 'page' : undefined}>{item.label}</a>;
      })}
      <LanguageSwitcher lang={lang} noAlternates={noAlternates} />
      <a href={bookHref} class="btn btn--gold nav-cta">{t('nav.book')}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 247, 241, 0.88);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 68px;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .brand-logo { height: 42px; width: auto; display: block; }
  .brand-name {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--brand-strong);
    letter-spacing: -0.01em;
  }
  .site-nav { display: flex; align-items: center; gap: 1.4rem; }
  .nav-link {
    position: relative;
    text-decoration: none;
    color: var(--text);
    font-weight: 500;
    font-size: 0.98rem;
    transition: color 0.15s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute; left: 0; right: 0; bottom: -6px; height: 2px;
    border-radius: 2px; background: var(--brand);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.22s ease;
  }
  .nav-link:hover::after,
  .nav-link[aria-current='page']::after { transform: scaleX(1); }
  .nav-link:hover { color: var(--brand); }
  .nav-link[aria-current='page'] { color: var(--brand); }
  .nav-cta { font-size: 0.92rem; padding: 0.6rem 1.1rem; }

  /* Beim Scrollen leicht anheben (scroll-driven, nur wo unterstützt). */
  @supports (animation-timeline: scroll()) {
    .site-header { animation: header-elevate linear both; animation-timeline: scroll(); animation-range: 0 120px; }
  }

  .burger { display: none; background: none; border: 0; }

  @keyframes header-elevate {
    to { box-shadow: 0 6px 24px rgba(13, 59, 68, 0.09); background: rgba(250, 247, 241, 0.94); }
  }

  @media (max-width: 860px) {
    .nav-link::after { content: none; } /* mobil trägt border-bottom die Trennung */
    .burger {
      display: inline-flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px;
    }
    .burger span {
      width: 26px; height: 2px; background: var(--brand-strong);
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    /* Burger → X, rein über den bestehenden aria-expanded-Toggle */
    .burger[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .burger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
    .burger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .site-nav {
      position: absolute;
      top: 100%;
      left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.4rem;
      background: var(--c-sand-50);
      padding: 1rem 1.2rem 1.4rem;
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-md);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.18s ease, transform 0.18s ease;
    }
    .site-nav.is-open { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .nav-link { padding: 0.6rem 0.2rem; border-bottom: 1px solid var(--line); }
    .nav-cta { margin-top: 0.6rem; justify-content: center; }
  }
</style>

<script>
  // Mobiles Menü: echter Button mit aria-expanded (A11y).
  document.querySelectorAll<HTMLButtonElement>('[data-navtoggle]').forEach((btn) => {
    const nav = document.getElementById('site-nav');
    if (!nav) return;
    btn.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(open));
    });
    nav.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        nav.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      })
    );
  });
</script>
