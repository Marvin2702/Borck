---
import HomeView from '../../components/HomeView.astro';
import { locales, defaultLang, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLang)
    .map((lang) => ({ params: { lang }, props: { lang } }));
}
const { lang } = Astro.props as { lang: Lang };
---
<HomeView lang={lang} />
