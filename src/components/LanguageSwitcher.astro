---
import Icon from './Icon.astro';
import { languages, locales, localizedPath, pageKeyFromUrl, useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; noAlternates?: boolean }
const { lang, noAlternates = false } = Astro.props;
const t = useTranslations(lang);

// Aktuellen sprachneutralen Pfad ermitteln (Base + Locale-Präfix entfernt).
const pageKey = pageKeyFromUrl(Astro.url);
// Auf einsprachigen Seiten (noAlternates) existieren keine Übersetzungen dieser
// URL -> Sprachlinks auf die jeweilige Sprach-Startseite zeigen (statt 404).
// Die statische 404-Datei liegt als /404.html vor; /404/ wäre daher selbst
// kein gültiges Ziel. Auf der Fehlerseite führen alle Sprachoptionen nach Hause.
const targetFor = (l: Lang) => (pageKey === '404' || (noAlternates && l !== lang) ? '' : pageKey);
---

<div class="lang" data-lang>
  <button
    type="button"
    class="lang-btn"
    aria-label={`${t('lang.label')}: ${languages[lang]}`}
    aria-expanded="false"
    aria-controls={`lang-menu-${lang}`}
  >
    <Icon name="globe" size={15} /> {lang.toUpperCase()}
  </button>
  {/* Native Linkliste: keine unvollständige ARIA-Menü-Tastatursteuerung nötig. */}
  <ul class="lang-menu" id={`lang-menu-${lang}`}>
    {locales.map((l) => (
      <li>
        <a href={localizedPath(targetFor(l), l)} hreflang={l}
           class={l === lang ? 'is-active' : ''} lang={l}
           aria-current={l === lang && targetFor(l) === pageKey ? 'page' : undefined}>
          {languages[l]}
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .lang { position: relative; }
  .lang-btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    background: transparent; border: 1px solid var(--line);
    border-radius: 999px; padding: 0.35rem 0.7rem;
    font: inherit; font-size: 0.85rem; font-weight: 600;
    color: var(--text); cursor: pointer;
  }
  .lang-btn:hover { border-color: var(--c-aqua-300); color: var(--brand); }
  .lang-menu {
    position: absolute; right: 0; top: calc(100% + 6px);
    list-style: none; margin: 0; padding: 0.35rem;
    background: var(--surface); border: 1px solid var(--line);
    border-radius: 12px; box-shadow: var(--shadow-md);
    min-width: 150px; opacity: 0; transform: translateY(-6px);
    pointer-events: none; visibility: hidden;
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0s linear 0.15s;
    z-index: 120;
  }
  .lang[data-open] .lang-menu {
    opacity: 1; transform: translateY(0); pointer-events: auto; visibility: visible;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .lang-menu a {
    display: block; padding: 0.5rem 0.7rem; border-radius: 8px;
    text-decoration: none; color: var(--text); font-size: 0.92rem;
  }
  .lang-menu a:hover { background: var(--c-aqua-100); }
  .lang-menu a.is-active { color: var(--brand); font-weight: 700; }
  @media (max-width: 860px) {
    .lang-menu {
      position: static; opacity: 1; transform: none; pointer-events: auto;
      visibility: inherit; box-shadow: none; margin-top: 0.4rem;
    }
    .lang-btn { display: none; }
  }
</style>

<script>
  // Dropdown per Klick (Desktop). Mobil ist die Liste im geöffneten Hauptmenü
  // sichtbar. Escape schließt das Dropdown und stellt den Fokus wieder her.
  const closeLanguageMenus = () => {
    document.querySelectorAll('[data-lang]').forEach((el) => {
      el.removeAttribute('data-open');
      el.querySelector('.lang-btn')?.setAttribute('aria-expanded', 'false');
    });
  };

  document.querySelectorAll('[data-lang]').forEach((el) => {
    const btn = el.querySelector<HTMLButtonElement>('.lang-btn');
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = el.hasAttribute('data-open');
      closeLanguageMenus();
      if (!open) el.setAttribute('data-open', '');
      btn.setAttribute('aria-expanded', String(!open));
    });
    el.addEventListener('keydown', (event) => {
      if ((event as KeyboardEvent).key === 'Escape' && el.hasAttribute('data-open')) {
        closeLanguageMenus();
        btn?.focus();
      }
    });
  });
  document.addEventListener('click', closeLanguageMenus);
</script>
