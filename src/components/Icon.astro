---
// Einheitliches Inline-SVG-Icon-Set (Stroke 1.8, currentColor) — ersetzt den
// Emoji-/Glyphen-Mix, der je nach Betriebssystem unterschiedlich rendert.
// Verwendung: <Icon name="paw" size={18} /> — erbt die Textfarbe.

interface Props {
  name: keyof typeof icons;
  size?: number;
  class?: string;
  /** Standard true: Icons sind dekorativ, Text steht daneben. */
  ariaHidden?: boolean;
}

const icons = {
  check: '<path d="M5 12.5l4.5 4.5L19 7.5"/>',
  heart:
    '<path d="M12 20.1C7.5 16.8 3.5 13.4 3.5 9.6 3.5 7.2 5.3 5.4 7.6 5.4c1.7 0 3.3 1 4.4 2.7 1.1-1.7 2.7-2.7 4.4-2.7 2.3 0 4.1 1.8 4.1 4.2 0 3.8-4 7.2-8.5 10.5z"/>',
  pin: '<path d="M12 21s-6.5-5.6-6.5-10.2a6.5 6.5 0 1 1 13 0C18.5 15.4 12 21 12 21z"/><circle cx="12" cy="10.6" r="2.3"/>',
  wave: '<path d="M2.5 9.5c2.4-2.4 4.9-2.4 7.3 0s4.9 2.4 7.3 0 3.3-1.8 4.4-.9"/><path d="M2.5 15.5c2.4-2.4 4.9-2.4 7.3 0s4.9 2.4 7.3 0 3.3-1.8 4.4-.9"/>',
  paw: '<g fill="currentColor" stroke="none"><ellipse cx="8.6" cy="7.6" rx="1.7" ry="2.1"/><ellipse cx="15.4" cy="7.6" rx="1.7" ry="2.1"/><ellipse cx="4.9" cy="11.2" rx="1.5" ry="1.9"/><ellipse cx="19.1" cy="11.2" rx="1.5" ry="1.9"/><path d="M12 11.2c2.8 0 5 2.2 5 4.6 0 1.8-1.4 2.9-2.9 2.9-.9 0-1.5-.45-2.1-.45s-1.2.45-2.1.45c-1.5 0-2.9-1.1-2.9-2.9 0-2.4 2.2-4.6 5-4.6z"/></g>',
  phone:
    '<path d="M5.2 4.2h2.9l1.5 3.9-1.9 1.7a12.4 12.4 0 0 0 6.5 6.5l1.7-1.9 3.9 1.5v2.9a1.9 1.9 0 0 1-2.1 1.9A16.6 16.6 0 0 1 3.3 6.3a1.9 1.9 0 0 1 1.9-2.1z"/>',
  mail: '<rect x="3.2" y="5.5" width="17.6" height="13" rx="2"/><path d="M3.8 7.2 12 13l8.2-5.8"/>',
  chat: '<path d="M20.8 11.8a8.3 8.3 0 0 1-12.2 7.3L3.6 20.4l1.3-4.8a8.3 8.3 0 1 1 15.9-3.8z"/>',
  gem: '<path d="M12 3.2 19.5 9.6 12 20.8 4.5 9.6z"/><path d="M4.5 9.6h15M12 3.2v17.6" stroke-width="1.2"/>',
  globe:
    '<circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17"/><path d="M12 3.5c3.1 2.7 3.1 14.3 0 17"/><path d="M12 3.5c-3.1 2.7-3.1 14.3 0 17"/>',
  calendar:
    '<rect x="3.5" y="5" width="17" height="15.5" rx="2"/><path d="M3.5 9.8h17"/><path d="M8 3v4M16 3v4"/>',
  'chevron-left': '<path d="M14.5 6 8.5 12l6 6"/>',
  'chevron-right': '<path d="M9.5 6l6 6-6 6"/>',
} as const;

const { name, size = 20, class: cls, ariaHidden = true } = Astro.props;
---
<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden ? 'true' : undefined}
  set:html={icons[name]}
/>
