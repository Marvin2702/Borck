---
import ThanksView from '../../components/ThanksView.astro';
import { locales, defaultLang, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return locales
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang }, props: { lang } }));
}
const { lang } = Astro.props as { lang: Lang };
---
<ThanksView lang={lang} />
