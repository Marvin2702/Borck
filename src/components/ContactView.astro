---
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from './Img.astro';
import { useTranslations, withBase, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const waText = encodeURIComponent(t('contact.whatsapp.msg'));
const title = `${t('contact.title')} · ${site.name} Büsum`;
// Ohne Web3Forms-Key wird KEIN Formular gerendert (kein stiller mailto-Fallback,
// der wie ein echter Versand aussieht) — stattdessen ein klarer Hinweis mit
// Direktkontakt. Key eintragen in src/data/site.ts (formAccessKey).
const hasFormKey = Boolean(site.formAccessKey);
---
<BaseLayout title={title} description={t('contact.subtitle')} pageKey="kontakt">
  <section class="section">
    <div class="container-narrow">
      <p class="eyebrow">{t('site.tagline')}</p>
      <h1>{t('contact.title')}</h1>
      <p class="lead">{t('contact.subtitle')}</p>

      <div class="contact-grid">
        <a class="contact-card" href={`tel:${site.phone.replace(/\s/g, '')}`}>
          <span class="ci">☎</span>
          <span class="cl">{t('contact.phone')}</span>
          <strong>{site.phoneDisplay}</strong>
        </a>
        <a class="contact-card" href={`https://wa.me/${site.whatsapp}?text=${waText}`} target="_blank" rel="noopener">
          <span class="ci">💬</span>
          <span class="cl">{t('contact.whatsapp')}</span>
          <strong>{site.phoneDisplay}</strong>
        </a>
        <a class="contact-card" href={`mailto:${site.email}`}>
          <span class="ci">✉</span>
          <span class="cl">{t('contact.email')}</span>
          <strong>{site.email}</strong>
        </a>
        <div class="contact-card">
          <span class="ci">📍</span>
          <span class="cl">{site.name}</span>
          <strong>{site.address.postalCode} {site.address.city}</strong>
        </div>
      </div>

      {hasFormKey ? (
        <form
          class="contact-form"
          data-contact-form
          action="https://api.web3forms.com/submit"
          method="POST"
          data-success={t('form.success')}
          data-error={t('form.error')}
          data-sending={t('form.sending')}
          data-dateorder={t('form.dateOrder')}
        >
          <input type="hidden" name="access_key" value={site.formAccessKey} />
          {/* Sprachkennung im Betreff: Die Gastgeberin sieht sofort, in welcher Sprache der Gast schreibt. */}
          <input type="hidden" name="subject" value={`Anfrage über ${site.name} Website (${lang.toUpperCase()})`} />
          <input type="hidden" name="from_name" value={site.name} />
          <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />
          <h2>{t('form.title')}</h2>
          <div class="form-row">
            <label>{t('form.name')}<input type="text" name="name" required autocomplete="name" /></label>
            <label>{t('contact.email')}<input type="email" name="email" required autocomplete="email" /></label>
          </div>
          <div class="form-row">
            <label>{t('form.arrival')}<input type="date" name="anreise" data-arrival /></label>
            <label>{t('form.departure')}<input type="date" name="abreise" data-departure /></label>
          </div>
          <label>{t('apartments.persons')}<input type="number" name="personen" min="1" max="6" inputmode="numeric" /></label>
          <label>{t('form.message')}<textarea name="message" rows="4" required></textarea></label>
          <button type="submit" class="btn btn--gold">{t('form.send')}</button>
          <p class="form-status" data-form-status role="status" aria-live="polite"></p>
        </form>
      ) : (
        <div class="contact-form contact-unavailable">
          <h2>{t('form.title')}</h2>
          <p class="form-status is-err" role="status">{t('form.unavailable')}</p>
          <div class="unavailable-actions">
            <a class="btn btn--gold" href={`mailto:${site.email}`}>✉ {site.email}</a>
            <a class="btn btn--ghost" href={`tel:${site.phone.replace(/\s/g, '')}`}>☎ {site.phoneDisplay}</a>
          </div>
        </div>
      )}

      <figure class="contact-image">
        <Img src="/images/kontakt-maritim.jpg" alt="Haus Aquamarin in Büsum"
             width={1200} height={600} loading="lazy" sizes="(min-width: 800px) 760px, 100vw" />
      </figure>
      <p class="addr-line">{site.name} · {site.address.street} · {site.address.postalCode} {site.address.city}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); margin: 2rem 0; }
  .contact-card {
    display: grid; gap: 0.25rem;
    background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 1.3rem 1.4rem;
    text-decoration: none; color: var(--text); box-shadow: var(--shadow-sm);
  }
  a.contact-card:hover { border-color: var(--c-aqua-300); transform: translateY(-2px); }
  .ci { font-size: 1.4rem; }
  .cl { color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .contact-card strong { color: var(--brand-strong); font-size: 1.1rem; }
  .contact-image { margin: 1.5rem 0 0.6rem; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
  .contact-image img { width: 100%; height: auto; display: block; object-fit: cover; aspect-ratio: 2 / 1; }
  .addr-line { color: var(--text-muted); text-align: center; }

  .contact-form {
    margin-top: 2.5rem; background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius-lg); padding: clamp(1.2rem, 0.8rem + 2vw, 2rem);
    box-shadow: var(--shadow-sm); display: grid; gap: 1rem;
  }
  .contact-form h2 { margin: 0; font-size: 1.5rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-form label { display: grid; gap: 0.35rem; font-size: 0.9rem; font-weight: 600; color: var(--text); }
  .contact-form input, .contact-form textarea {
    font: inherit; font-weight: 400; padding: 0.7rem 0.85rem;
    border: 1px solid var(--line); border-radius: 10px; background: var(--c-sand-50); color: var(--text);
  }
  .contact-form input:focus, .contact-form textarea:focus { outline: 2px solid var(--brand); outline-offset: 1px; border-color: transparent; }
  .contact-form button { justify-self: start; }
  .hp { position: absolute; left: -9999px; }
  .form-status { margin: 0; font-weight: 600; }
  .form-status.is-ok { color: var(--c-deich-700); }
  .form-status.is-err { color: #a52a3a; }
  .unavailable-actions { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .contact-form button[disabled] { opacity: 0.6; cursor: progress; transform: none; }
  @media (max-width: 600px) { .contact-grid, .form-row { grid-template-columns: 1fr; } }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  if (form) {
    const status = form.querySelector<HTMLElement>('[data-form-status]');
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const arrival = form.querySelector<HTMLInputElement>('[data-arrival]');
    const departure = form.querySelector<HTMLInputElement>('[data-departure]');

    // Native Datumsfelder: Anreise frühestens heute, Abreise nach der Anreise.
    const isoDate = (d: Date) => d.toISOString().slice(0, 10);
    const dayAfter = (iso: string) => {
      const d = new Date(`${iso}T12:00:00`);
      d.setDate(d.getDate() + 1);
      return isoDate(d);
    };
    if (arrival) arrival.min = isoDate(new Date());
    const syncDepartureMin = () => {
      if (!arrival || !departure) return;
      departure.min = arrival.value ? dayAfter(arrival.value) : (arrival.min ? dayAfter(arrival.min) : '');
      // Abreise vor/gleich Anreise? Native Validierungsmeldung setzen.
      if (departure.value && arrival.value && departure.value <= arrival.value) {
        departure.setCustomValidity(form.dataset.dateorder || '');
      } else {
        departure.setCustomValidity('');
      }
    };
    arrival?.addEventListener('change', syncDepartureMin);
    departure?.addEventListener('change', syncDepartureMin);
    syncDepartureMin();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (form.dataset.busy === '1') return; // Doppel-Submit verhindern
      syncDepartureMin();
      if (!form.reportValidity()) return;
      form.dataset.busy = '1';
      if (submitBtn) submitBtn.disabled = true;
      if (status) { status.textContent = form.dataset.sending || '…'; status.className = 'form-status'; }
      try {
        const data = new FormData(form);
        const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
        // Erfolg NUR melden, wenn der Server ihn bestätigt (Web3Forms: JSON success).
        const json = await res.json().catch(() => null);
        if (!res.ok || !json || json.success !== true) throw new Error('bad');
        form.reset();
        if (status) { status.textContent = form.dataset.success || ''; status.className = 'form-status is-ok'; }
      } catch {
        if (status) { status.textContent = form.dataset.error || ''; status.className = 'form-status is-err'; }
      } finally {
        delete form.dataset.busy;
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
