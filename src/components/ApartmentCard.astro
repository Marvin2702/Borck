---
import { useTranslations, localizedPath, type Lang } from '../i18n/utils';
import { priceFrom } from '../data/prices';
import { trApt } from '../data/apartments-i18n';
import Img from './Img.astro';
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';
import { galleryImageAlt } from '../data/gallery-alt';

interface Props {
  apartment: CollectionEntry<'apartments'>;
  lang: Lang;
  /** Responsive sizes-Angabe fürs Kartenbild (z. B. breiter bei Featured-Karten). */
  sizes?: string;
}
const { apartment, lang, sizes } = Astro.props;
const t = useTranslations(lang);
const d = apartment.data;
const href = localizedPath(`apartments/${apartment.id}`, lang);
const accent = d.accent;
const price = priceFrom(d.smoobu_id, d.price_from);
const tr = trApt(apartment.id, lang);
const view = tr?.view ?? d.view;
const summary = tr?.summary ?? d.summary;
// Der Buchungs-CTA bleibt in der eigenen Trust-Umgebung und springt zum
// eingebetteten Smoobu-Kalender auf der Detailseite.
const bookUrl = `${href}#buchung`;
// Karten-Galerie: alle Fotos direkt auf der Karte durchblätterbar,
// damit niemand die Seite verlassen muss, um sich zu entscheiden.
// In Übersichten reichen vier Motive zur Auswahl. Die vollständige Galerie
// bleibt auf der Detailseite; das reduziert HTML und Bild-Requests erheblich.
const gallery: string[] = (d.gallery?.length ? d.gallery : d.heroImage ? [d.heroImage] : []).slice(0, 4);
---

<article class="card apt" data-apt
  data-persons={d.persons}
  data-dog={d.dogFriendly ? '1' : '0'}
  data-seaview={d.view.toLowerCase().includes('meerblick') ? '1' : '0'}>
  {gallery.length > 0 ? (
    <div class="apt-media" data-carousel>
      <div class="apt-track" data-track>
        {gallery.map((src, i) => (
          <a class="apt-slide" href={href} tabindex={i === 0 ? undefined : -1}>
            <Img
              src={src}
              alt={galleryImageAlt(src, d.name, lang, view)}
              width={640}
              height={400}
              loading="lazy"
              sizes={sizes ?? '(max-width: 600px) 100vw, (max-width: 960px) 50vw, 33vw'}
            />
          </a>
        ))}
      </div>
      {gallery.length > 1 && (
        <>
          {/* hidden bis JS initialisiert — ohne JS bleibt natives Swipen */}
          <button type="button" class="apt-nav apt-nav--prev" data-prev aria-label={t('gallery.prev')} hidden>
            <Icon name="chevron-left" size={18} />
          </button>
          <button type="button" class="apt-nav apt-nav--next" data-next aria-label={t('gallery.next')} hidden>
            <Icon name="chevron-right" size={18} />
          </button>
          <span class="apt-dots" aria-hidden="true">
            {gallery.map((_, i) => <span class={i === 0 ? 'apt-dot is-on' : 'apt-dot'}></span>)}
          </span>
        </>
      )}
      <span class="apt-badge" style={`--a:${accent}`}>{view}</span>
      {d.dogFriendly && <span class="apt-dog" title="Hundefreundlich" aria-hidden="true"><Icon name="paw" size={15} /></span>}
    </div>
  ) : (
    <a href={href} class="apt-media">
      <span class="apt-placeholder" style={`--a:${accent}`}>
        <span class="apt-gem" aria-hidden="true">◈</span>
      </span>
      <span class="apt-badge" style={`--a:${accent}`}>{view}</span>
      {d.dogFriendly && <span class="apt-dog" title="Hundefreundlich" aria-hidden="true"><Icon name="paw" size={15} /></span>}
    </a>
  )}

  <div class="apt-body">
    <h3 class="apt-name"><a href={href}>{d.name}</a></h3>
    <p class="apt-summary">{summary}</p>
    <ul class="apt-meta">
      <li><strong>{d.persons}</strong> {t('apartments.persons')}</li>
      {d.size_qm && <li><strong>{d.size_qm}</strong> m²</li>}
      {d.bedrooms && <li><strong>{d.bedrooms}</strong> {d.bedrooms === 1 ? t('apartments.bedroom') : t('apartments.bedrooms')}</li>}
    </ul>
    <div class="apt-foot">
      {price
        ? <span class="apt-price">{t('apartments.from')} <strong>{price} €</strong> / {t('apartments.night')}</span>
        : <span class="apt-price apt-price--tbd">{t('apartments.priceDynamic')}</span>}
      <div class="apt-actions">
        <a href={href} class="btn btn--ghost apt-details">{t('apartments.details')}</a>
        {/* Karten-CTA in Aqua — Gold bleibt den Seiten-Primär-CTAs vorbehalten */}
        <a href={bookUrl} class="btn apt-book" data-track-event="select_apartment" data-track-apartment={apartment.id} data-track-location="card">{t('cta.bookNow')}</a>
      </div>
    </div>
  </div>
</article>

<style>
  .apt { display: flex; flex-direction: column; }
  .apt:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .apt-media { position: relative; display: block; aspect-ratio: 16 / 10; overflow: hidden; }
  /* :global nötig: das <img> stammt aus Img.astro (Kind-Komponente) und trägt die
     Scope-Klasse dieser Karte nicht — sonst greifen object-fit & Hover-Zoom nie. */
  .apt-media :global(img) { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .apt:hover .apt-media :global(img) { transform: scale(1.05); }

  /* Karten-Galerie: native Scroll-Snap-Spur (Swipe mobil), Pfeile per JS */
  .apt-track {
    position: absolute; inset: 0;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
  }
  .apt-track::-webkit-scrollbar { display: none; }
  .apt-slide { flex: 0 0 100%; display: block; height: 100%; overflow: hidden; scroll-snap-align: start; scroll-snap-stop: always; }
  .apt-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    display: grid; place-items: center;
    width: 36px; height: 36px; border-radius: 999px; border: 0;
    background: rgba(255, 255, 255, 0.92); color: var(--c-ink-900);
    cursor: pointer; box-shadow: var(--shadow-sm);
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .apt-nav:hover { background: #fff; transform: translateY(-50%) scale(1.06); }
  .apt-nav:active { transform: translateY(-50%) scale(0.94); }
  .apt-nav--prev { left: 10px; }
  .apt-nav--next { right: 10px; }
  /* Touch: 44px-Tap-Targets */
  @media (pointer: coarse) {
    .apt-nav { width: 44px; height: 44px; }
  }
  /* Fokusring innen zeichnen — außen würde ihn overflow:hidden abschneiden */
  .apt-slide:focus-visible { outline: 2px solid #fff; outline-offset: -4px; border-radius: 6px; }
  .apt-dots {
    position: absolute; left: 50%; bottom: 12px; transform: translateX(-50%);
    display: flex; gap: 5px; pointer-events: none;
  }
  .apt-dot { width: 6px; height: 6px; border-radius: 999px; background: rgba(255, 255, 255, 0.55); box-shadow: 0 0 4px rgba(0, 0, 0, 0.25); transition: background 0.2s ease; }
  .apt-dot.is-on { background: #fff; }
  .apt-placeholder {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    background:
      radial-gradient(120% 120% at 20% 10%, color-mix(in srgb, var(--a) 55%, white), var(--a) 70%, color-mix(in srgb, var(--a) 70%, black));
  }
  .apt-gem { font-size: 2.6rem; color: rgba(255, 255, 255, 0.85); }
  .apt-badge {
    position: absolute; left: 12px; bottom: 12px;
    background: rgba(255, 255, 255, 0.92);
    color: color-mix(in srgb, var(--a) 75%, black);
    font-weight: 700; font-size: 0.78rem;
    padding: 0.3rem 0.7rem; border-radius: 999px;
  }
  .apt-dog { position: absolute; right: 12px; top: 12px; display: grid; place-items: center; background: rgba(255,255,255,0.9); border-radius: 999px; padding: 0.35rem; color: var(--c-ink-700); }
  .apt-body { padding: 1.2rem 1.3rem 1.4rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  .apt-name { margin: 0; font-size: 1.4rem; }
  .apt-name a { color: inherit; text-decoration: none; }
  .apt-name a:hover { color: var(--brand); }
  .apt-summary { color: var(--text-muted); margin: 0; font-size: 0.95rem; flex: 1; }
  .apt-meta { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.1rem; margin: 0.4rem 0; padding: 0; font-size: 0.9rem; color: var(--text-muted); font-variant-numeric: tabular-nums; }
  .apt-meta strong { color: var(--text); }
  .apt-foot { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 0.5rem; }
  .apt-price { font-size: 0.95rem; color: var(--text-muted); font-variant-numeric: tabular-nums; }
  /* Der Preis ist buchungsentscheidend — typografisch führen lassen */
  .apt-price strong { color: var(--brand-strong); font-size: 1.3rem; font-weight: 700; }
  .apt-price--tbd strong { color: var(--text-muted); font-size: 0.95rem; }
  .apt-actions { display: flex; gap: 0.5rem; }
  .apt-details { padding: 0.6rem 0.9rem; font-size: 0.9rem; }
  .apt-book { flex: 1; justify-content: center; white-space: nowrap; }
  @media (max-width: 420px) {
    .apt-actions { flex-direction: column-reverse; }
    .apt-actions .btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  // Karten-Galerie: Pfeile blättern die Scroll-Snap-Spur, Punkte zeigen die
  // Position. Ohne JS bleiben die Pfeile hidden — natives Swipen geht trotzdem.
  const smooth = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((media) => {
    const track = media.querySelector<HTMLElement>('[data-track]');
    if (!track || track.children.length < 2) return;
    media.querySelectorAll<HTMLButtonElement>('.apt-nav').forEach((b) => (b.hidden = false));
    const dots = Array.from(media.querySelectorAll<HTMLElement>('.apt-dot'));

    const go = (dir: number) => {
      const max = track.scrollWidth - track.clientWidth;
      let left = Math.round(track.scrollLeft + dir * track.clientWidth);
      if (left > max + 4) left = 0; // am Ende wieder von vorn …
      if (left < -4) left = max; // … und am Anfang ans Ende
      track.scrollTo({ left, behavior: smooth ? 'smooth' : 'auto' });
    };
    media.querySelector('[data-prev]')?.addEventListener('click', () => go(-1));
    media.querySelector('[data-next]')?.addEventListener('click', () => go(1));

    let raf = 0;
    track.addEventListener(
      'scroll',
      () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const i = Math.round(track.scrollLeft / track.clientWidth);
          dots.forEach((d, k) => d.classList.toggle('is-on', k === i));
        });
      },
      { passive: true }
    );
  });
</script>
