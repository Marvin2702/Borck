---
import BaseLayout from '../layouts/BaseLayout.astro';
import { type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang; kind: 'impressum' | 'datenschutz' | 'agb' }
const { lang, kind } = Astro.props;

const titles = {
  impressum: 'Impressum',
  datenschutz: 'Datenschutzerklärung',
  agb: 'AGB & Buchungsbedingungen',
};
const title = `${titles[kind]} – ${site.name}`;
---
<BaseLayout title={title} description={titles[kind]} pageKey={kind} noindex={kind !== 'impressum'}>
  <section class="section">
    <div class="container-narrow">
      <h1>{titles[kind]}</h1>
      <div class="legal-note">
        {/* TODO: Bestehenden, rechtlich geprüften Text von nordsee-buesum-fewo.de
            1:1 übernehmen (Impressum/Datenschutz/AGB sind rechtlich verbindlich
            und dürfen nicht frei umformuliert werden). */}
        <p><strong>Platzhalter.</strong> Hier wird der bestehende, rechtlich
          geprüfte {titles[kind]}-Text der aktuellen Website eingesetzt. Bitte
          den Originaltext übernehmen – nicht neu formulieren.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-note {
    border: 1px dashed var(--c-aqua-300);
    background: var(--c-aqua-100);
    border-radius: var(--radius);
    padding: 1.2rem 1.4rem;
    color: var(--text-muted);
  }
</style>
