---
// Bild mit moderner Format-Aushandlung (AVIF -> WebP -> JPG), base-path-aware.
// Erwartet einen /images/<name>.jpg-Pfad; die .webp/.avif-Varianten liegen daneben
// (erzeugt via scripts/gen-image-variants.mjs).
import { withBase } from '../i18n/utils';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto' | 'low';
  sizes?: string;
}
const { src, alt, width, height, class: cls, loading = 'lazy', fetchpriority, sizes } = Astro.props;
const base = src.replace(/\.(jpe?g|png)$/i, '');
const widths = [640, 1024, 1600];
const srcset = (ext: string) => widths.map((w) => `${withBase(`${base}-${w}.${ext}`)} ${w}w`).join(', ');
const fallbackSizes = sizes ?? '100vw';
---
<picture>
  <source type="image/avif" srcset={srcset('avif')} sizes={fallbackSizes} />
  <source type="image/webp" srcset={srcset('webp')} sizes={fallbackSizes} />
  <img
    src={withBase(`${base}.jpg`)}
    srcset={srcset('jpg')}
    sizes={fallbackSizes}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
    class={cls}
  />
</picture>
