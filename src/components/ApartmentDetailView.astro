---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from './BookingWidget.astro';
import Img from './Img.astro';
import { useTranslations, localizedPath, withBase, type Lang } from '../i18n/utils';
import { priceFrom } from '../data/prices';
import { site } from '../data/site';

interface Props { lang: Lang; apartment: CollectionEntry<'apartments'> }
const { lang, apartment } = Astro.props;
const t = useTranslations(lang);
const d = apartment.data;
const { Content } = await render(apartment);

const origin = Astro.site ?? new URL(site.domain);
const detailUrl = new URL(localizedPath(`apartments/${apartment.id}`, lang), origin).href;
const price = priceFrom(d.smoobu_id, d.price_from);

const title = `Ferienwohnung ${d.name} · ${site.name} Büsum`;
const description = `Ferienwohnung ${d.name} in Büsum: ${d.summary} Für ${d.persons} ${t('apartments.persons')}, ${d.view}.`;

// JSON-LD: Apartment (+ Offer, falls Preis). Reguläres Schema.org.
const apartmentLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Apartment',
  name: `${site.name} · ${d.name}`,
  description: d.summary,
  url: detailUrl,
  image: d.gallery.map((g) => new URL(withBase(g), origin).href),
  occupancy: { '@type': 'QuantitativeValue', maxValue: d.persons },
  numberOfBedrooms: d.bedrooms,
  numberOfRooms: d.bedrooms,
  petsAllowed: d.dogFriendly,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  ...(d.size_qm
    ? { floorSize: { '@type': 'QuantitativeValue', value: d.size_qm, unitCode: 'MTK' } }
    : {}),
  amenityFeature: d.features.map((f) => ({ '@type': 'LocationFeatureSpecification', name: f })),
  ...(price
    ? {
        offers: {
          '@type': 'Offer',
          price,
          priceCurrency: 'EUR',
          availability: 'https://schema.org/InStock',
          url: detailUrl,
        },
      }
    : {}),
};

// Breadcrumb (Start › Apartments › {Name}) für die SERP-Darstellung.
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home'), item: new URL(localizedPath('', lang), origin).href },
    { '@type': 'ListItem', position: 2, name: t('apartments.title'), item: new URL(localizedPath('apartments', lang), origin).href },
    { '@type': 'ListItem', position: 3, name: d.name, item: detailUrl },
  ],
};
---
<BaseLayout
  title={title}
  description={description}
  pageKey={`apartments/${apartment.id}`}
  image={d.heroImage}
  jsonLd={[apartmentLd, breadcrumbLd]}
>
  <article>
    <header class="apt-hero" style={`--a:${d.accent}`}>
      <div class="container apt-hero-inner">
        <a class="back" href={localizedPath('apartments', lang)}>← {t('apartments.title')}</a>
        <p class="eyebrow">{d.view}</p>
        <h1>{d.name}</h1>
        <p class="lead">{d.summary}</p>
        <ul class="apt-facts">
          <li><strong>{d.persons}</strong> {t('apartments.persons')}</li>
          {d.bedrooms && <li><strong>{d.bedrooms}</strong> {d.bedrooms === 1 ? t('apartments.bedroom') : t('apartments.bedrooms')}</li>}
          {d.size_qm && <li><strong>{d.size_qm}</strong> m²</li>}
          {price && <li>{t('apartments.from')} <strong>{price} €</strong>/{t('apartments.night')}</li>}
        </ul>
      </div>
    </header>

    {d.gallery.length > 0 && (
      <section class="apt-gallery-sec">
        <div class="container">
          <div class={`apt-gallery count-${Math.min(d.gallery.length, 3)}`}>
            {d.gallery.map((src, i) => (
              <figure class={i === 0 ? 'g-main' : ''} data-lightbox-item>
                <Img src={src} alt={`Ferienwohnung ${d.name} in Büsum, Ansicht ${i + 1}`}
                     width={1200} height={800}
                     loading={i === 0 ? 'eager' : 'lazy'}
                     fetchpriority={i === 0 ? 'high' : undefined}
                     sizes="(max-width: 820px) 100vw, 66vw" />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section">
      <div class="container detail-grid">
        <div class="detail-body">
          <Content />
        </div>
        <aside class="detail-aside">
          <h2 class="aside-title">{t('apartments.features')}</h2>
          <ul class="feature-list">
            {d.features.map((f) => <li>✓ {f}</li>)}
          </ul>
          {d.dogFriendly && <p class="dog-badge">🐾 {t('usp.pets.title')}</p>}
          <a href="#buchung" class="btn btn--gold" style="margin-top:1rem;width:100%;justify-content:center">
            {t('nav.book')}
          </a>
        </aside>
      </div>
    </section>

    <BookingWidget lang={lang} smoobuId={d.smoobu_id} apartmentName={d.name} />

    <div class="sticky-cta">
      <span class="sticky-price">
        {price ? <span>{t('apartments.from')} <strong>{price} €</strong></span> : <strong>{d.name}</strong>}
      </span>
      <a href="#buchung" class="btn btn--gold">{t('nav.book')}</a>
    </div>

    <div class="lightbox" data-lightbox hidden>
      <button class="lightbox-close" type="button" aria-label="Schließen" data-lightbox-close>×</button>
      <img class="lightbox-img" alt="" />
    </div>
  </article>
</BaseLayout>

<style>
  .apt-hero { background: linear-gradient(150deg, color-mix(in srgb, var(--a) 22%, white), var(--c-sand-50)); border-bottom: 1px solid var(--line); }
  .apt-hero-inner { padding-block: clamp(2rem, 1.2rem + 4vw, 4rem); }
  .apt-hero h1 { color: color-mix(in srgb, var(--a) 70%, black); }
  .apt-hero .eyebrow { color: color-mix(in srgb, var(--a) 65%, black); }
  .back { display: inline-block; margin-bottom: 1rem; text-decoration: none; font-weight: 600; color: var(--brand); }
  .apt-facts { list-style: none; display: flex; flex-wrap: wrap; gap: 0.6rem 1.6rem; padding: 0; margin: 1.2rem 0 0; color: var(--text-muted); }
  .apt-facts strong { color: var(--text); }
  .detail-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2.5rem; align-items: start; }
  .detail-body { font-size: 1.05rem; }
  .detail-aside { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); position: sticky; top: 90px; }
  .aside-title { font-size: 1.2rem; margin-top: 0; }
  .feature-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.55rem; }
  .feature-list li { color: var(--text); }
  .dog-badge { margin-top: 1rem; color: var(--brand); font-weight: 600; }
  @media (max-width: 820px) { .detail-grid { grid-template-columns: 1fr; } .detail-aside { position: static; } }

  .apt-gallery-sec { padding-top: clamp(1.5rem, 1rem + 2vw, 2.5rem); }
  .apt-gallery { display: grid; gap: 0.8rem; }
  .apt-gallery figure { margin: 0; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); }
  .apt-gallery img { width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 3 / 2; }
  .apt-gallery.count-2 { grid-template-columns: 1fr 1fr; }
  .apt-gallery.count-3 { grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr; }
  .apt-gallery.count-3 .g-main { grid-row: 1 / 3; }
  .apt-gallery.count-3 .g-main img { aspect-ratio: auto; min-height: 100%; }
  @media (max-width: 640px) {
    .apt-gallery, .apt-gallery.count-2, .apt-gallery.count-3 { grid-template-columns: 1fr; grid-template-rows: none; }
    .apt-gallery.count-3 .g-main { grid-row: auto; }
  }

  /* Galerie-Lightbox */
  .lightbox { position: fixed; inset: 0; z-index: 300; background: rgba(13, 59, 68, 0.92); display: grid; place-items: center; padding: 1.5rem; }
  .lightbox[hidden] { display: none; }
  .lightbox-img { max-width: 95vw; max-height: 90vh; border-radius: 8px; box-shadow: var(--shadow-lg); }
  .lightbox-close { position: absolute; top: 0.8rem; right: 1.2rem; background: none; border: 0; color: #fff; font-size: 2.6rem; line-height: 1; cursor: pointer; }

  /* Sticky Buchungs-CTA (mobil) */
  .sticky-cta {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
    display: none; align-items: center; justify-content: space-between; gap: 1rem;
    background: rgba(255, 255, 255, 0.96); backdrop-filter: blur(8px);
    border-top: 1px solid var(--line); padding: 0.7rem 1.1rem;
    box-shadow: 0 -4px 20px rgba(13, 59, 68, 0.1);
  }
  .sticky-price strong { color: var(--brand-strong); font-size: 1.15rem; }
  @media (max-width: 820px) {
    .sticky-cta { display: flex; }
    article { padding-bottom: 76px; }
  }
</style>

<script>
  // Galerie-Lightbox
  const lb = document.querySelector<HTMLElement>('[data-lightbox]');
  const lbImg = lb?.querySelector('.lightbox-img') as HTMLImageElement | null;
  const closeLb = () => { if (lb) { lb.hidden = true; document.body.style.overflow = ''; } };
  document.querySelectorAll<HTMLImageElement>('[data-lightbox-item] img').forEach((img) => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => {
      if (!lb || !lbImg) return;
      lbImg.src = img.currentSrc || img.src;
      lbImg.alt = img.alt || '';
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
    });
  });
  lb?.addEventListener('click', (e) => {
    const target = e.target as Element;
    if (target === lb || target.hasAttribute('data-lightbox-close')) closeLb();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLb(); });
</script>
