---
import { useTranslations, localizedPath, withBase, type Lang } from '../i18n/utils';
import { site } from '../data/site';
import Icon from './Icon.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const bookHref = localizedPath('apartments', lang);
const apartmentsHref = '#apartments-preview';
// Bewertungswert mit lokalisiertem Dezimaltrennzeichen (4,6 vs. 4.6).
const ratingStr = site.rating.value.toFixed(1).replace('.', lang === 'en' ? '.' : ',');
const facts: Record<Lang, { distance: string; direct: string; host: string }> = {
  de: { distance: '400 m zur Familienlagune', direct: 'Ohne Portalgebühr', host: 'Direkt bei Iris' },
  en: { distance: '400 m to the family lagoon', direct: 'No platform fee', host: 'Direct with Iris' },
  nl: { distance: '400 m van de familielagune', direct: 'Geen platformkosten', host: 'Direct bij Iris' },
  da: { distance: '400 m til familielagunen', direct: 'Intet portalgebyr', host: 'Direkte hos Iris' },
};
const f = facts[lang];
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <picture>
      <source media="(max-width: 720px)" srcset={withBase('images/hero-buesum-v2-768.webp')} />
      <source media="(max-width: 1360px)" srcset={withBase('images/hero-buesum-v2-1280.webp')} />
      <img src={withBase('images/hero-buesum-v2.webp')} alt="" width="1862" height="845" fetchpriority="high" />
    </picture>
  </div>

  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow hero-eyebrow">{t('hero.eyebrow')}</p>
      <h1 class="hero-title">{t('hero.title')}</h1>
      <p class="lead hero-sub">{t('hero.subtitle')}</p>
      <div class="hero-cta">
        <a href={bookHref} class="btn btn--gold btn--lg">{t('hero.cta.book')}</a>
        <a href={apartmentsHref} class="btn btn--glass btn--lg">{t('hero.cta.apartments')}</a>
      </div>
      <a class="hero-trust" href="#bewertungen" aria-label={`${ratingStr} von 5 – ${site.rating.count} ${t('reviews.count')}`}>
        <span class="stars" aria-hidden="true">★</span>
        <strong>{ratingStr}</strong>
        <span>· {site.rating.count} {t('reviews.count')}</span>
      </a>
    </div>
    <ul class="hero-facts" aria-label="Vorteile">
      <li><Icon name="pin" size={15} />{f.distance}</li>
      <li><Icon name="check" size={15} />{f.direct}</li>
      <li><Icon name="heart" size={15} />{f.host}</li>
    </ul>
  </div>
</section>

{/* Startet geparkt (SSR-Klasse): verhindert Aufblitzen vor dem ersten
    IntersectionObserver-Callback. Ohne JS zeigt <noscript> die Leiste. */}
<div class="mobile-booking is-parked" aria-label={t('hero.cta.book')}>
  <div><strong>{ratingStr} ★</strong><span>{f.direct}</span></div>
  <a href={bookHref} class="btn btn--gold">{t('hero.cta.book')}</a>
</div>
<noscript><style>.mobile-booking.is-parked { transform: none; opacity: 1; pointer-events: auto; }</style></noscript>

<style>
  .hero { position: relative; overflow: hidden; isolation: isolate; min-height: min(760px, calc(100svh - 68px)); display: grid; }
  .hero-bg { position: absolute; inset: 0; z-index: -1; }
  .hero-bg picture, .hero-bg img { width: 100%; height: 100%; display: block; }
  .hero-bg img { object-fit: cover; object-position: center; }
  .hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(6, 35, 43, .88) 0%, rgba(8, 48, 58, .72) 37%, rgba(8, 48, 58, .18) 68%, rgba(8, 48, 58, .08) 100%); }
  .hero-inner {
    /* KEIN width:100% — sonst verliert .container seine Randabstände und der
       Text klebt an der Viewport-Kante (Grid-Child: margin-inline auto zentriert). */
    align-self: end;
    padding-block: clamp(3rem, 9vw, 7.5rem) clamp(2.2rem, 5vw, 4rem);
  }
  .hero-copy { max-width: 650px; }
  .hero-eyebrow { color: var(--c-gold-300); }
  .hero-title { color: #fff; max-width: 18ch; font-size: clamp(2.65rem, 6vw, 5.25rem); text-shadow: 0 2px 24px rgba(0,0,0,.24); }
  .hero-sub { color: rgba(255,255,255,.88); margin-bottom: 2rem; max-width: 56ch; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .btn--glass { color: #fff; border: 1px solid rgba(255,255,255,.64); background: rgba(255,255,255,.1); backdrop-filter: blur(8px); }
  .btn--glass:hover { background: #fff; color: var(--brand-strong); }
  .hero-trust {
    margin-top: 2rem; display: inline-flex; align-items: center; gap: 0.6rem;
    color: #fff; font-weight: 600; font-size: 0.95rem;
    text-decoration: none;
  }
  .hero-trust:hover { color: var(--c-gold-300); }
  .stars { color: var(--c-gold-300); letter-spacing: 2px; }
  .hero-facts { display: flex; flex-wrap: wrap; gap: .65rem; padding: 0; margin: 2.2rem 0 0; list-style: none; }
  .hero-facts li { display: inline-flex; gap: .45rem; align-items: center; padding: .48rem .75rem; border-radius: 999px; color: #fff; background: rgba(4,29,35,.52); border: 1px solid rgba(255,255,255,.24); backdrop-filter: blur(8px); font-size: .88rem; font-weight: 650; }
  .hero-facts li :global(svg) { color: var(--c-gold-300); flex: none; }
  .mobile-booking { display: none; }

  /* Dezenter Auftritt: gestaffeltes Aufsteigen der Copy, langsames Zoom-Settle
     des Bildes. Nur bei erlaubter Motion; ohne Guard keine versteckten Zustände. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-copy > * { animation: hero-rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) backwards; }
    .hero-copy > :nth-child(2) { animation-delay: 0.08s; }
    .hero-copy > :nth-child(3) { animation-delay: 0.16s; }
    .hero-copy > :nth-child(4) { animation-delay: 0.24s; }
    .hero-copy > :nth-child(5) { animation-delay: 0.3s; }
    .hero-facts { animation: hero-rise 0.7s 0.38s cubic-bezier(0.2, 0.7, 0.2, 1) backwards; }
    @media (min-width: 721px) {
      .hero-bg img { animation: hero-zoom 22s ease-out both; }
    }
  }
  @keyframes hero-rise { from { opacity: 0; transform: translateY(14px); } }
  @keyframes hero-zoom { from { transform: scale(1.05); } to { transform: scale(1); } }

  @media (max-width: 720px) {
    .hero { min-height: 690px; }
    .hero-bg img { object-position: 61% center; }
    .hero-bg::after { background: linear-gradient(180deg, rgba(4,28,34,.22) 0%, rgba(4,28,34,.42) 34%, rgba(4,28,34,.94) 82%, rgba(4,28,34,.98) 100%); }
    .hero-inner { padding-block: 7rem 2.1rem; align-self: end; }
    .hero-title { font-size: clamp(2.55rem, 12vw, 3.7rem); }
    .hero-sub { font-size: 1.04rem; }
    .hero-cta .btn { flex: 1 1 100%; }
    .hero-facts { gap: .45rem; }
    .hero-facts li { font-size: .78rem; padding: .42rem .6rem; }
    .mobile-booking { position: fixed; z-index: 180; left: .65rem; right: .65rem; bottom: calc(.65rem + env(safe-area-inset-bottom, 0px)); display: flex; align-items: center; justify-content: space-between; gap: .8rem; padding: .65rem .7rem .65rem 1rem; border-radius: 16px; color: #fff; background: rgba(6,42,51,.94); box-shadow: 0 10px 34px rgba(0,0,0,.28); backdrop-filter: blur(14px); transition: transform .3s ease, opacity .3s ease; }
    .mobile-booking div { display: grid; line-height: 1.15; }
    .mobile-booking span { font-size: .72rem; color: rgba(255,255,255,.72); }
    .mobile-booking .btn { padding: .7rem .9rem; font-size: .8rem; white-space: nowrap; min-height: 44px; }
    /* Solange der Hero (mit identischem CTA) im Bild ist, bleibt die Leiste
       geparkt — Klasse wird NUR per JS gesetzt; ohne JS heutiges Verhalten. */
    .mobile-booking.is-parked { transform: translateY(140%); opacity: 0; pointer-events: none; }
  }
</style>

<script>
  // Mobile Buchungsleiste erst zeigen, wenn der Hero (mit identischem CTA)
  // aus dem Viewport gescrollt ist — sonst doppelter Gold-CTA im ersten Fold.
  const bar = document.querySelector<HTMLElement>('.mobile-booking');
  const hero = document.querySelector<HTMLElement>('.hero');
  if (bar && hero && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => bar.classList.toggle('is-parked', e.isIntersecting)),
      { threshold: 0.25 }
    );
    io.observe(hero);
  }
</script>
