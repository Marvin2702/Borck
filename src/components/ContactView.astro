---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import Img from './Img.astro';
import Icon from './Icon.astro';
import { localizedPath, useTranslations, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const waText = encodeURIComponent(t('contact.whatsapp.msg'));
const title = `${t('contact.title')} · ${site.name} Büsum`;
// Apartment-Auswahl fürs Formular (buildtime aus der Collection).
const apartments = (await getCollection('apartments')).sort((a, b) => a.data.order - b.data.order);
const maxGuests = Math.max(...apartments.map((a) => a.data.persons), 1);
const thanksHref = localizedPath('danke', lang);
const thanksUrl = new URL(thanksHref, Astro.site ?? new URL(site.domain)).href;
const privacyHref = localizedPath('datenschutz', 'de');
const formUi: Record<Lang, {
  datePair: string;
  dateOrder: string;
  capacity: string;
  sending: string;
  metaDescription: string;
  privacyPrefix: string;
  privacyLink: string;
}> = {
  de: {
    datePair: 'Bitte wähle Anreise und Abreise gemeinsam aus.',
    dateOrder: 'Die Abreise muss nach der Anreise liegen.',
    capacity: 'Dieses Apartment ist für höchstens {capacity} Personen ausgelegt.',
    sending: 'Anfrage wird gesendet …',
    metaDescription: 'Haus Aquamarin in Büsum direkt kontaktieren: Ferienwohnung mit Reisezeitraum und Gästezahl anfragen oder Iris per Telefon, WhatsApp und E-Mail erreichen.',
    privacyPrefix: 'Mit dem Absenden gilt unsere',
    privacyLink: 'Datenschutzerklärung',
  },
  en: {
    datePair: 'Please select both arrival and departure.',
    dateOrder: 'Departure must be after arrival.',
    capacity: 'This apartment accommodates a maximum of {capacity} guests.',
    sending: 'Sending your enquiry …',
    metaDescription: 'Contact Haus Aquamarin in Büsum directly: enquire about an apartment with dates and guest count, or reach Iris by phone, WhatsApp and email.',
    privacyPrefix: 'When submitting, our',
    privacyLink: 'privacy policy (German)',
  },
  nl: {
    datePair: 'Kies zowel aankomst als vertrek.',
    dateOrder: 'Het vertrek moet na de aankomst liggen.',
    capacity: 'Dit appartement is geschikt voor maximaal {capacity} personen.',
    sending: 'Je aanvraag wordt verstuurd …',
    metaDescription: 'Neem rechtstreeks contact op met Haus Aquamarin in Büsum: vraag een appartement aan met reisdata en aantal gasten, of bel, app of mail Iris.',
    privacyPrefix: 'Bij het verzenden geldt onze',
    privacyLink: 'privacyverklaring (Duits)',
  },
  da: {
    datePair: 'Vælg både ankomst og afrejse.',
    dateOrder: 'Afrejsen skal ligge efter ankomsten.',
    capacity: 'Denne lejlighed har plads til højst {capacity} personer.',
    sending: 'Din forespørgsel sendes …',
    metaDescription: 'Kontakt Haus Aquamarin i Büsum direkte: forespørg på en lejlighed med datoer og antal gæster, eller kontakt Iris via telefon, WhatsApp og e-mail.',
    privacyPrefix: 'Ved afsendelse gælder vores',
    privacyLink: 'privatlivspolitik (tysk)',
  },
};
const f = formUi[lang];
---
<BaseLayout title={title} description={f.metaDescription} pageKey="kontakt">
  <section class="section">
    <div class="container-narrow">
      <Breadcrumbs lang={lang} items={[{ label: t('contact.title'), href: localizedPath('kontakt', lang) }]} />
      <p class="eyebrow">{t('site.tagline')}</p>
      <h1>{t('contact.title')}</h1>
      <p class="lead">{t('contact.subtitle')}</p>

      <div class="contact-grid">
        <a class="contact-card" href={`tel:${site.phone.replace(/\s/g, '')}`} data-track-location="contact_page">
          <span class="ci"><Icon name="phone" size={22} /></span>
          <span class="cl">{t('contact.phone')}</span>
          <strong>{site.phoneDisplay}</strong>
        </a>
        <a class="contact-card" href={`https://wa.me/${site.whatsapp}?text=${waText}`} target="_blank" rel="noopener" data-track-location="contact_page">
          <span class="ci"><Icon name="chat" size={22} /></span>
          <span class="cl">{t('contact.whatsapp')}</span>
          <strong>{site.phoneDisplay}</strong>
        </a>
        <a class="contact-card" href={`mailto:${site.email}`}>
          <span class="ci"><Icon name="mail" size={22} /></span>
          <span class="cl">{t('contact.email')}</span>
          <strong>{site.email}</strong>
        </a>
        <div class="contact-card">
          <span class="ci"><Icon name="pin" size={22} /></span>
          <span class="cl">{site.name}</span>
          <strong>{site.address.postalCode} {site.address.city}</strong>
        </div>
      </div>

      <form
        class="contact-form"
        data-contact-form
        action="https://api.web3forms.com/submit"
        method="POST"
        data-haskey={site.formAccessKey ? '1' : '0'}
        data-email={site.email}
        data-language={lang}
        data-thanks={thanksHref}
        data-success={t('form.success')}
        data-error={t('form.error')}
        data-mailtohint={`${t('form.mailtoHint')} ${site.email} · ${site.phoneDisplay}`}
        data-date-pair={f.datePair}
        data-date-order={f.dateOrder}
        data-capacity={f.capacity}
        data-sending={f.sending}
      >
        <input type="hidden" name="access_key" value={site.formAccessKey} />
        <input type="hidden" name="subject" value={`Anfrage über ${site.name} Website`} />
        <input type="hidden" name="from_name" value={site.name} />
        <input type="hidden" name="redirect" value={thanksUrl} />
        <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="form-head">
          <span class="form-portrait" aria-hidden="true">
            <Img src="/images/iris-mia.jpg" alt="" width={112} height={112} loading="lazy" sizes="56px" />
          </span>
          <div>
            <h2>{t('form.title')}</h2>
            <p class="form-greeting">{t('form.greeting')}</p>
          </div>
        </div>
        <div class="form-row">
          <label>{t('form.name')}<input type="text" name="name" required autocomplete="name" /></label>
          <label>{t('contact.email')}<input type="email" name="email" required autocomplete="email" /></label>
        </div>
        <div class="form-row">
          <label>{t('form.arrival')}<input type="date" name="arrival" autocomplete="off" data-arrival /></label>
          <label>{t('form.departure')}<input type="date" name="departure" autocomplete="off" data-departure /></label>
        </div>
        <div class="form-row">
          <label>{t('form.apartment')}
            <select name="apartment" data-apartment-select>
              <option value="">{t('form.apartmentAny')}</option>
              {apartments.map((a) => <option value={a.data.name} data-capacity={a.data.persons}>{a.data.name}</option>)}
            </select>
          </label>
          <label>{t('apartments.persons')}<input type="number" name="guests" min="1" max={maxGuests} inputmode="numeric" data-guests /></label>
        </div>
        <label>{t('form.message')}<textarea name="message" rows="4" required></textarea></label>
        <button type="submit" class="btn btn--gold" data-submit>{t('form.send')}</button>
        <p class="form-privacy">{f.privacyPrefix} <a href={privacyHref}>{f.privacyLink}</a>.</p>
        <p class="form-status" data-form-status role="status" aria-live="polite"></p>
      </form>

      <figure class="contact-image">
        <Img src="/images/kontakt-maritim.jpg" alt="Haus Aquamarin in Büsum"
             width={1200} height={600} loading="lazy" sizes="100vw" />
      </figure>
      <p class="addr-line">{site.name} · {site.address.street} · {site.address.postalCode} {site.address.city}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); margin: 2rem 0; }
  .contact-card {
    display: grid; gap: 0.25rem;
    background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 1.3rem 1.4rem;
    text-decoration: none; color: var(--text); box-shadow: var(--shadow-sm);
  }
  a.contact-card:hover { border-color: var(--c-aqua-300); transform: translateY(-2px); }
  .ci { color: var(--brand); }
  .cl { color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .contact-card strong { color: var(--brand-strong); font-size: 1.1rem; }
  .contact-image { margin: 1.5rem 0 0.6rem; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
  /* :global nötig: <img> kommt aus Img.astro und trägt die Scope-Klasse nicht. */
  .contact-image :global(img) { width: 100%; height: auto; display: block; object-fit: cover; aspect-ratio: 2 / 1; }
  .addr-line { color: var(--text-muted); text-align: center; }

  .contact-form {
    margin-top: 2.5rem; background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius-lg); padding: clamp(1.2rem, 0.8rem + 2vw, 2rem);
    box-shadow: var(--shadow-sm); display: grid; gap: 1rem;
  }
  .contact-form h2 { margin: 0; font-size: 1.5rem; }
  .form-head { display: flex; align-items: center; gap: 0.9rem; }
  .form-portrait { flex: none; width: 56px; height: 56px; border-radius: 999px; overflow: hidden; box-shadow: var(--shadow-sm); }
  .form-portrait :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .form-greeting { margin: 0.15rem 0 0; color: var(--text-muted); font-family: var(--font-head); font-style: italic; font-size: 1.02rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-form label { display: grid; gap: 0.35rem; font-size: 0.9rem; font-weight: 600; color: var(--text); }
  .contact-form input, .contact-form textarea, .contact-form select {
    font: inherit; font-weight: 400; padding: 0.7rem 0.85rem;
    border: 1px solid var(--line); border-radius: 10px; background: var(--c-sand-50); color: var(--text);
    min-height: 44px;
  }
  .contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus { outline: 2px solid var(--brand); outline-offset: 1px; border-color: transparent; }
  .contact-form button { justify-self: start; }
  .hp { display: none; }
  .form-status { margin: 0; font-weight: 600; }
  .form-privacy { margin: -0.3rem 0 0; color: var(--text-muted); font-size: 0.8rem; }
  .form-privacy a { color: var(--brand); }
  .form-status.is-ok { color: var(--c-deich-700); }
  .form-status.is-err { color: #a52a3a; }
  @media (max-width: 600px) {
    .contact-grid, .form-row { grid-template-columns: 1fr; }
    .contact-form button { justify-self: stretch; width: 100%; }
  }
</style>

<script>
  const PENDING_LEAD_KEY = 'ha-pending-lead-v1';
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  if (form) {
    const status = form.querySelector<HTMLElement>('[data-form-status]');
    const arrival = form.querySelector<HTMLInputElement>('[data-arrival]');
    const departure = form.querySelector<HTMLInputElement>('[data-departure]');
    const apartment = form.querySelector<HTMLSelectElement>('[data-apartment-select]');
    const guests = form.querySelector<HTMLInputElement>('[data-guests]');
    const submit = form.querySelector<HTMLButtonElement>('[data-submit]');
    const submitLabel = submit?.textContent || '';
    const defaultCapacity = Number(guests?.max || 1);

    const pad = (value: number) => String(value).padStart(2, '0');
    const today = (() => {
      const now = new Date();
      return `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;
    })();
    const addDays = (iso: string, days: number) => {
      const [year, month, day] = iso.split('-').map(Number);
      const date = new Date(Date.UTC(year, month - 1, day + days));
      return `${date.getUTCFullYear()}-${pad(date.getUTCMonth() + 1)}-${pad(date.getUTCDate())}`;
    };

    if (arrival) arrival.min = today;
    if (departure) departure.min = addDays(today, 1);

    const selectedCapacity = () => {
      const selected = apartment?.selectedOptions[0];
      return Number(selected?.dataset.capacity || defaultCapacity);
    };

    const validateDates = () => {
      if (!arrival || !departure) return true;
      arrival.setCustomValidity('');
      departure.setCustomValidity('');
      if (arrival.value && !departure.value) {
        departure.setCustomValidity(form.dataset.datePair || '');
        return false;
      }
      if (!arrival.value && departure.value) {
        arrival.setCustomValidity(form.dataset.datePair || '');
        return false;
      }
      if (arrival.value && departure.value && departure.value <= arrival.value) {
        departure.setCustomValidity(form.dataset.dateOrder || '');
        return false;
      }
      return true;
    };

    const validateCapacity = () => {
      if (!guests) return true;
      guests.setCustomValidity('');
      const capacity = selectedCapacity();
      const count = Number(guests.value);
      guests.max = String(capacity || Number(guests.max) || 1);
      if (guests.value && capacity > 0 && count > capacity) {
        guests.setCustomValidity((form.dataset.capacity || '').replace('{capacity}', String(capacity)));
        return false;
      }
      return true;
    };

    const validate = () => {
      const datesValid = validateDates();
      const capacityValid = validateCapacity();
      return datesValid && capacityValid && form.checkValidity();
    };

    arrival?.addEventListener('input', () => {
      if (departure) departure.min = arrival.value ? addDays(arrival.value, 1) : addDays(today, 1);
      validateDates();
    });
    departure?.addEventListener('input', validateDates);
    apartment?.addEventListener('change', validateCapacity);
    guests?.addEventListener('input', validateCapacity);

    const setSubmitting = (busy: boolean) => {
      form.dataset.submitting = busy ? '1' : '0';
      if (!submit) return;
      submit.disabled = busy;
      submit.setAttribute('aria-busy', busy ? 'true' : 'false');
      submit.textContent = busy ? (form.dataset.sending || submitLabel) : submitLabel;
    };

    const markPendingLead = () => {
      const id = typeof crypto.randomUUID === 'function'
        ? crypto.randomUUID()
        : `${Date.now()}-${Math.random().toString(36).slice(2)}`;
      try {
        sessionStorage.setItem(PENDING_LEAD_KEY, JSON.stringify({ id, createdAt: Date.now(), method: 'web3forms' }));
      } catch { /* Lead wird versendet; nur die anonyme Erfolgsmessung entfällt. */ }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (form.dataset.submitting === '1') return;
      if (!validate()) {
        form.reportValidity();
        return;
      }
      const data = new FormData(form);
      // Ohne Web3Forms-Key: mailto-Fallback (öffnet das E-Mail-Programm).
      if (form.dataset.haskey !== '1') {
        const subject = encodeURIComponent('Anfrage Ferienwohnung Büsum');
        const body = encodeURIComponent(
          `Name: ${data.get('name')}\nE-Mail: ${data.get('email')}\n` +
          `Anreise: ${data.get('arrival')}\nAbreise: ${data.get('departure')}\n` +
          `Apartment: ${data.get('apartment') || '-'}\nPersonen: ${data.get('guests')}\n\n${data.get('message')}`
        );
        window.location.href = `mailto:${form.dataset.email}?subject=${subject}&body=${body}`;
        // Ehrliches Feedback: ohne eingerichtetes Mail-Programm passiert sonst
        // scheinbar nichts — Hinweis mit direkter Kontaktmöglichkeit anzeigen.
        if (status) { status.textContent = form.dataset.mailtohint || ''; status.className = 'form-status is-ok'; }
        return;
      }
      if (status) { status.textContent = '…'; status.className = 'form-status'; }
      setSubmitting(true);
      try {
        const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
        const result = await res.json().catch(() => null);
        if (!res.ok || result?.success !== true) throw new Error('submission_failed');
        markPendingLead();
        form.reset();
        if (departure) departure.min = addDays(today, 1);
        validateCapacity();
        if (status) { status.textContent = form.dataset.success || ''; status.className = 'form-status is-ok'; }
        window.location.assign(form.dataset.thanks || '/danke/');
      } catch {
        if (status) { status.textContent = form.dataset.error || ''; status.className = 'form-status is-err'; }
      } finally {
        setSubmitting(false);
      }
    });
  }
</script>
