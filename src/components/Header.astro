---
import { useTranslations, localizedPath, withBase, type Lang } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { site } from '../data/site';

interface Props { lang: Lang; noAlternates?: boolean }
const { lang, noAlternates = false } = Astro.props;
const t = useTranslations(lang);

const nav = [
  { key: 'apartments', label: t('nav.apartments') },
  { key: 'lage', label: t('nav.location') },
  // Reiseführer-Cluster nur auf Deutsch (Content DE-only).
  ...(lang === 'de' ? [{ key: 'reisefuehrer', label: 'Reiseführer' }] : []),
  { key: 'ueber-uns', label: t('nav.about') },
  { key: 'kontakt', label: t('nav.contact') },
];
const home = localizedPath('', lang);
const bookHref = localizedPath('apartments', lang);
---

<header class="site-header">
  <div class="container header-inner">
    <a href={home} class="brand" aria-label={site.name}>
      <picture>
        <source srcset={withBase('/images/logo.webp')} type="image/webp" />
        <img src={withBase('/images/logo.png')} alt="" class="brand-logo" width="44" height="44" />
      </picture>
      <span class="brand-name">{site.name}</span>
    </a>

    <button type="button" class="burger" aria-label={t('nav.menu')} aria-expanded="false" aria-controls="site-nav" data-navtoggle>
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav" aria-label={t('nav.menu')}>
      {nav.map((item) => (
        <a href={localizedPath(item.key, lang)} class="nav-link">{item.label}</a>
      ))}
      <LanguageSwitcher lang={lang} noAlternates={noAlternates} />
      <a href={bookHref} class="btn btn--gold nav-cta">{t('nav.book')}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 247, 241, 0.88);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 68px;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .brand-logo { height: 42px; width: auto; display: block; }
  .brand-name {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--brand-strong);
    letter-spacing: -0.01em;
  }
  .site-nav { display: flex; align-items: center; gap: 1.4rem; }
  .nav-link {
    text-decoration: none;
    color: var(--text);
    font-weight: 500;
    font-size: 0.98rem;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--brand); }
  .nav-cta { font-size: 0.92rem; padding: 0.6rem 1.1rem; }

  .burger { display: none; background: none; border: 0; }

  @media (max-width: 860px) {
    .burger {
      display: inline-flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px;
    }
    .burger span {
      width: 26px; height: 2px; background: var(--brand-strong);
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    .site-nav {
      position: absolute;
      top: 100%;
      left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.4rem;
      background: var(--c-sand-50);
      padding: 1rem 1.2rem 1.4rem;
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-md);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      /* visibility nimmt die Links zusätzlich aus Tab-Reihenfolge & A11y-Tree;
         das visibility-Delay lässt die Ausblend-Animation zu Ende laufen. */
      visibility: hidden;
      transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
    }
    .site-nav.is-open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      visibility: visible;
      transition: opacity 0.18s ease, transform 0.18s ease;
    }
    .nav-link { padding: 0.6rem 0.2rem; border-bottom: 1px solid var(--line); }
    .nav-cta { margin-top: 0.6rem; justify-content: center; }
  }
</style>

<script>
  // Mobiles Menü: echter Button mit aria-expanded, Escape schließt und gibt den
  // Fokus an den Button zurück (A11y). Geschlossen ist das Menü via CSS
  // visibility:hidden auch aus der Tab-Reihenfolge entfernt.
  document.querySelectorAll<HTMLButtonElement>('[data-navtoggle]').forEach((btn) => {
    const nav = document.getElementById('site-nav');
    if (!nav) return;
    const isOpen = () => nav.classList.contains('is-open');
    const setOpen = (open: boolean) => {
      nav.classList.toggle('is-open', open);
      btn.setAttribute('aria-expanded', String(open));
    };
    btn.addEventListener('click', () => setOpen(!isOpen()));
    nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) {
        setOpen(false);
        btn.focus();
      }
    });
    // Klick außerhalb schließt das offene Menü (mobil).
    document.addEventListener('click', (e) => {
      if (isOpen() && e.target instanceof Node && !nav.contains(e.target) && !btn.contains(e.target)) {
        setOpen(false);
      }
    });
  });
</script>
