---
import Icon from './Icon.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props {
  lang: Lang;
  /** Smoobu-Objekt-ID (Apartment). Leer => Gruppen-ID, sonst Kontakt-Fallback. */
  smoobuId?: string;
  apartmentName?: string;
}
const { lang, smoobuId, apartmentName } = Astro.props as Props;
const t = useTranslations(lang);

const effectiveId = smoobuId || site.smoobuGroupId || '';
const hasId = effectiveId.length > 0;
// Smoobu-Sprachsegment der Booking-Tool-URL (Fallback DE bei unbekannt).
const smoobuLang = ({ de: 'de', en: 'en', nl: 'nl', da: 'da' } as Record<string, string>)[lang] ?? 'de';
const waText = encodeURIComponent(t('contact.whatsapp.msg'));
---

<section class="booking" id="buchung">
  <div class="container-narrow booking-head">
    <p class="eyebrow">{t('booking.title')}</p>
    <h2>{apartmentName ? apartmentName : t('booking.title')}</h2>
    <p class="lead">{t('booking.subtitle')}</p>
  </div>

  <div class="container-narrow booking-shell">
    {hasId ? (
      <div
        class="booking-embed"
        data-id={effectiveId}
        data-user={site.smoobuUserId}
        data-lang={smoobuLang}
        data-phone={site.phone.replace(/\s/g, '')}
        data-phonelabel={site.phoneDisplay}
        data-wa={`https://wa.me/${site.whatsapp}?text=${waText}`}
        data-fbtitle={t('booking.fallbackTitle')}
        data-fbtext={t('booking.fallbackText')}
      >
        {/* Kalender-Skeleton als Ladezustand (statt nacktem Textsatz) */}
        <div class="booking-skel" aria-hidden="true">
          <span class="sk sk-head"></span>
          <span class="sk sk-row"></span>
          <span class="sk sk-cal"></span>
        </div>
        <p class="booking-hint">{t('booking.placeholder')}</p>
      </div>
    ) : (
      <div class="booking-placeholder">
        <div class="ph-cta">
          <p class="ph-note">{t('booking.subtitle')}</p>
          <div class="ph-buttons">
            <a class="btn btn--gold" href={`tel:${site.phone.replace(/\s/g, '')}`}><Icon name="phone" size={17} /> {site.phoneDisplay}</a>
            <a class="btn btn--ghost" href={`https://wa.me/${site.whatsapp}?text=${waText}`} rel="noopener" target="_blank">WhatsApp</a>
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .booking { padding-block: var(--section-y); background: linear-gradient(180deg, var(--c-aqua-100), color-mix(in srgb, var(--c-aqua-100) 35%, var(--c-white))); }
  .booking-head { text-align: center; margin-bottom: 2rem; }
  .booking-head .lead { margin-inline: auto; color: var(--c-ink-700); }
  .booking-shell {
    background: var(--surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: clamp(1rem, 0.6rem + 1.6vw, 1.8rem);
    min-height: 360px;
    display: grid;
  }
  .booking-embed { display: grid; place-items: center; gap: 1rem; align-content: center; min-height: 320px; text-align: center; }
  .booking-embed[data-loaded] { display: block; place-items: stretch; }
  .booking-hint { color: var(--text-muted); font-size: 0.9rem; }
  /* Skeleton in Sand-Tönen: Kopfzeile, Wochentagszeile, Monatsraster */
  .booking-skel { display: grid; gap: 0.7rem; justify-items: center; width: min(100%, 420px); }
  .sk { display: block; border-radius: 8px; background: var(--c-sand-100); }
  .sk-head { width: 55%; height: 1.1rem; }
  .sk-row { width: 90%; height: 0.75rem; }
  .sk-cal {
    width: 90%; height: 150px; border-radius: 12px;
    background:
      repeating-linear-gradient(90deg, var(--c-sand-100) 0 calc(100% / 7 - 6px), transparent calc(100% / 7 - 6px) calc(100% / 7)),
      repeating-linear-gradient(0deg, transparent 0 24px, var(--c-sand-50) 24px 30px);
  }
  @media (prefers-reduced-motion: no-preference) {
    .sk, .sk-cal { animation: sk-pulse 1.6s ease-in-out infinite; }
  }
  @keyframes sk-pulse { 50% { opacity: 0.55; } }
  /* Gestalteter Fallback (per JS gerendert): Karte mit Titel + Kontaktwegen */
  .booking-embed :global(.booking-fb) { display: grid; gap: 0.5rem; justify-items: center; max-width: 46ch; }
  .booking-embed :global(.booking-fb strong) { font-family: var(--font-head); font-size: 1.35rem; color: var(--brand-strong); }
  .booking-embed :global(.booking-fb p) { color: var(--text-muted); margin: 0 0 0.5rem; }
  .booking-embed :global(.booking-fb .fb-btns) { display: flex; gap: 0.7rem; flex-wrap: wrap; justify-content: center; }
  .booking-placeholder { display: grid; place-items: center; min-height: 280px; text-align: center; }
  .ph-note { color: var(--text-muted); }
  .ph-buttons { display: flex; gap: 0.7rem; flex-wrap: wrap; justify-content: center; }
  /* Smoobu-iFrame responsiv */
  .booking-shell :global(iframe) { width: 100% !important; border: 0; }
</style>

<script>
  // Lazy-Load des Smoobu Booking-Tools (schützt CWV/INP). Exaktes Format aus
  // der Originalseite: BookingToolIframe.js + /<lang>/booking-tool/iframe/<user>/<id>.
  function showFallback(el: HTMLElement) {
    if (el.dataset.fallback || el.querySelector('iframe')) return;
    el.dataset.fallback = '1';
    const phone = el.dataset.phone || '';
    const phoneLabel = el.dataset.phonelabel || phone;
    const wa = el.dataset.wa || '#';
    const esc = (s: string) => s.replace(/</g, '&lt;');
    const phoneIcon =
      '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5.2 4.2h2.9l1.5 3.9-1.9 1.7a12.4 12.4 0 0 0 6.5 6.5l1.7-1.9 3.9 1.5v2.9a1.9 1.9 0 0 1-2.1 1.9A16.6 16.6 0 0 1 3.3 6.3a1.9 1.9 0 0 1 1.9-2.1z"/></svg>';
    el.innerHTML =
      '<div class="booking-fb">' +
      `<strong>${esc(el.dataset.fbtitle || '')}</strong>` +
      `<p>${esc(el.dataset.fbtext || '')}</p>` +
      '<div class="fb-btns">' +
      `<a class="btn btn--gold" href="tel:${phone}">${phoneIcon} ${esc(phoneLabel)}</a>` +
      `<a class="btn btn--ghost" href="${wa}" target="_blank" rel="noopener">WhatsApp</a>` +
      '</div></div>';
  }

  function initSmoobu(el: HTMLElement) {
    if (el.dataset.loaded) return;
    el.dataset.loaded = '1';
    const id = el.dataset.id;
    const user = el.dataset.user;
    const lang = el.dataset.lang || 'de';
    const base = 'https://login.smoobu.com';
    const targetId = `smoobuApartment${id}${lang}`;
    el.innerHTML = `<div id="${targetId}"></div>`;
    const s = document.createElement('script');
    s.src = `${base}/js/Settings/BookingToolIframe.js`;
    s.async = true;
    s.onload = () => {
      // @ts-ignore – global von Smoobu bereitgestellt
      if (window.BookingToolIframe) {
        // @ts-ignore
        window.BookingToolIframe.initialize({
          url: `${base}/${lang}/booking-tool/iframe/${user}/${id}`,
          baseUrl: base,
          target: `#${targetId}`,
        });
        // Smoobu-iFrame nachträglich mit Titel versehen (A11y: frame-title).
        let tries = 0;
        const ti = setInterval(() => {
          const f = el.querySelector('iframe') as HTMLIFrameElement | null;
          if (f) { if (!f.title) f.title = 'Buchungskalender'; clearInterval(ti); }
          else if (++tries > 40) clearInterval(ti);
        }, 250);
      } else {
        showFallback(el);
      }
    };
    s.onerror = () => showFallback(el);
    document.body.appendChild(s);
    // Sicherheitsnetz: erscheint nach 8 s kein iFrame (Adblock/CSP/Netz), Kontakt anbieten.
    setTimeout(() => showFallback(el), 8000);
  }

  // Automatisch laden, sobald der Kalender in Sichtnähe kommt (kein Klick nötig).
  // Lazy via IntersectionObserver schützt weiterhin CWV/INP beim Initial-Load.
  document.querySelectorAll<HTMLElement>('.booking-embed').forEach((el) => {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { initSmoobu(el); io.disconnect(); } });
    }, { rootMargin: '500px' });
    io.observe(el);
  });

  // Sicherheitsnetz: Feuert der Observer nie (gedrosselte/versteckte Tabs,
  // exotische Browser), bliebe sonst dauerhaft "Kalender wird geladen …" stehen —
  // auch der 8-s-Kontakt-Fallback startet erst in initSmoobu. Deshalb spätestens
  // 6 s nach Load initialisieren (LCP/CWV sind dann längst gemessen; Doppel-Init
  // verhindert das dataset.loaded-Guard).
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll<HTMLElement>('.booking-embed').forEach((el) => initSmoobu(el));
    }, 6000);
  }, { once: true });
</script>
