---
import BaseLayout from '../layouts/BaseLayout.astro';
import { type Lang } from '../i18n/utils';
import { site } from '../data/site';
import { legal } from '../data/legal';

interface Props { lang: Lang; kind: 'impressum' | 'datenschutz' | 'agb' }
const { lang, kind } = Astro.props;

const titles = {
  impressum: 'Impressum',
  datenschutz: 'Datenschutzerklärung',
  agb: 'AGB & Buchungsbedingungen',
};
const title = `${titles[kind]} · ${site.name}`;
const imp = site.impressum;
const doc = kind !== 'impressum' ? legal[kind] : null;
---
<BaseLayout title={title} description={titles[kind]} pageKey={kind} noAlternates={true}>
  <section class="section">
    <div class="container-narrow legal">
      <h1>{titles[kind]}</h1>

      {kind === 'impressum' ? (
        <div class="legal-body">
          <p>Angaben gemäß § 5 DDG / § 5 TMG</p>
          <p>
            <strong>{imp.operator}</strong><br />
            Ferienapartmentvermietung „{site.name}"<br />
            {imp.street}<br />
            {imp.postalCode} {imp.city}<br />
            {imp.country}
          </p>
          <p>
            <strong>Kontakt</strong><br />
            Telefon: {imp.phone} (alternativ {imp.phoneAlt})<br />
            E-Mail: <a href={`mailto:${imp.email}`}>{imp.email}</a>
          </p>
          <p>
            <strong>Umsatzsteuer-Identifikationsnummer</strong> (§ 27a UStG)<br />
            {imp.ustId}
          </p>
          <p>
            <strong>Objekt-Anschrift</strong><br />
            {site.name}, {site.address.street}, {site.address.postalCode} {site.address.city}
          </p>
          <p class="note">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV: {imp.operator}, {imp.street}, {imp.postalCode} {imp.city}.</p>
        </div>
      ) : (
        <div class="legal-body" set:html={doc!.html} />
      )}

      {doc && <p class="legal-stand">Stand: {doc.stand}</p>}
    </div>
  </section>
</BaseLayout>

<style>
  .legal-body :global(h3) { font-size: 1.2rem; margin: 1.8rem 0 0.6rem; }
  .legal-body :global(p) { margin: 0 0 0.9rem; }
  .legal-body :global(ul) { margin: 0 0 1rem; padding-left: 1.3rem; }
  .legal-body :global(li) { margin-bottom: 0.3rem; }
  .legal-body :global(.note) { color: var(--text-muted); font-size: 0.9rem; }
  .legal-stand { color: var(--text-muted); font-size: 0.85rem; margin-top: 2rem; }
</style>
