---
import ContactView from '../../components/ContactView.astro';
import { locales, defaultLang, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLang)
    .map((lang) => ({ params: { lang }, props: { lang } }));
}
const { lang } = Astro.props as { lang: Lang };
---
<ContactView lang={lang} />
