---
import { useTranslations, withBase, type Lang } from '../i18n/utils';
import Icon from './Icon.astro';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// „Persönlich geführt" trägt das traditionelle Logo (Wiedererkennung),
// die übrigen USPs bleiben beim ruhigen Strich-Icon-Set.
const items = [
  { icon: 'check', title: t('usp.direct.title'), text: t('usp.direct.text') },
  { icon: 'logo', title: t('usp.host.title'), text: t('usp.host.text') },
  { icon: 'wave', title: t('usp.location.title'), text: t('usp.location.text') },
  { icon: 'paw', title: t('usp.pets.title'), text: t('usp.pets.text') },
] as const;
---
<section class="section usp-section">
  <div class="container">
    <div class="usp-grid">
      {items.map((i) => (
        <div class="usp">
          <span class="usp-icon" aria-hidden="true">
            {i.icon === 'logo' ? (
              <img src={withBase('/images/logo.png')} alt="" class="usp-logo" width="30" height="30" loading="lazy" />
            ) : (
              <Icon name={i.icon} size={22} />
            )}
          </span>
          <h2 class="usp-title">{i.title}</h2>
          <p class="usp-text">{i.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Entkartet: ruhige typografische Zeile mit feiner Oberkante statt 4 Boxen */
  .usp-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--gap); }
  .usp { padding-top: 1.2rem; border-top: 2px solid var(--c-sand-200); }
  .usp-icon {
    display: inline-grid; place-items: center;
    width: 44px; height: 44px; border-radius: 12px;
    background: var(--c-aqua-100); color: var(--c-aqua-700);
    margin-bottom: 0.9rem;
  }
  .usp-title { font-family: var(--font-body); font-weight: 650; font-size: 1.05rem; margin: 0 0 0.4rem; }
  .usp-text { color: var(--text-muted); margin: 0; font-size: 0.95rem; hyphens: auto; }
  @media (max-width: 900px) { .usp-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) {
    .usp-grid { grid-template-columns: 1fr 1fr; gap: 1.1rem; }
    .usp { padding-top: 0.9rem; }
    .usp-icon { width: 36px; height: 36px; border-radius: 10px; margin-bottom: 0.6rem; }
    .usp-text { font-size: 0.82rem; }
  }
</style>
