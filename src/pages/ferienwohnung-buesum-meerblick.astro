---
import { getCollection } from 'astro:content';
import ThemeLandingView from '../components/ThemeLandingView.astro';

const all = (await getCollection('apartments')).sort((a, b) => a.data.order - b.data.order);
// Meerblick zuerst, ergänzt um Wohnungen mit Deich-/Balkonblick.
const seaview = all.filter((a) => a.data.view.toLowerCase().includes('meerblick'));
const withView = all.filter((a) => /meer|deich|balkon/i.test(a.data.view));
const apartments = seaview.length ? withView : all;
---
<ThemeLandingView
  lang="de"
  pageKey="ferienwohnung-buesum-meerblick"
  metaTitle="Ferienwohnung Büsum mit Meerblick · Haus Aquamarin"
  metaDescription="Ferienwohnung in Büsum mit Meerblick und Deichblick. Im obersten Apartment Topas sehen Sie die Nordsee zuerst – bis 5 Personen, Balkon, ohne Buchungsgebühr direkt buchen."
  eyebrow="Meer- & Deichblick · Büsum"
  h1="Ferienwohnung in Büsum mit Meerblick"
  intro={[
    "Wer ganz oben wohnt, sieht das Meer zuerst: Das Apartment Topas in der zweiten Etage bietet echten Meerblick für bis zu fünf Personen. Mehrere weitere Wohnungen punkten mit Deichblick und Balkon.",
    "Alle Apartments liegen direkt hinter der Familienlagune Perlebucht, wenige Schritte von Strand und Promenade. Verfügbarkeit und Preise prüfen Sie direkt im Kalender des jeweiligen Apartments.",
  ]}
  apartments={apartments}
/>
