{
  "name": "haus-aquamarin",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "uuid": "^11.1.1"
  },
  "description": "Relaunch nordsee-buesum-fewo.de — Haus Aquamarin Büsum (Astro + Smoobu)",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/fetch-prices.mjs",
    "build": "astro build",
    "postbuild": "node scripts/audit-build.mjs",
    "build:with-app": "node scripts/build-with-guest-app.mjs",
    "build:guest-app": "node scripts/build-guest-app.mjs",
    "audit:build": "node scripts/audit-build.mjs",
    "audit:guest-app": "node scripts/audit-guest-app.mjs",
    "audit:links": "node scripts/audit-external-links.mjs",
    "audit:lighthouse": "lhci autorun",
    "build:test": "PUBLIC_GA4_ID=G-CI00000000 PUBLIC_WEB3FORMS_ACCESS_KEY=ci-public-test-key REQUIRE_INDEXABLE=true npm run build",
    "build:test:with-app": "PUBLIC_GA4_ID=G-CI00000000 PUBLIC_WEB3FORMS_ACCESS_KEY=ci-public-test-key REQUIRE_INDEXABLE=true npm run build:with-app",
    "test:e2e": "npm run build:test && playwright test",
    "test:e2e:run": "playwright test",
    "test:e2e:with-app": "npm run build:test:with-app && PUBLIC_GUEST_APP_ENABLED=true playwright test",
    "test:e2e:with-app:run": "PUBLIC_GUEST_APP_ENABLED=true playwright test",
    "preview": "astro preview",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/fraunces": "^5.2.9",
    "astro": "^7.0.7",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "sharp": "^0.35.3",
    "typescript": "^7.0.2"
  }
}
