# Cloudflare Pages: Sicherheitsheader für alle Dokumente.
/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://api.web3forms.com; script-src 'self' 'unsafe-inline' https://login.smoobu.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://tile.openstreetmap.org https://www.google-analytics.com; font-src 'self' data:; connect-src 'self' https://api.web3forms.com https://www.google-analytics.com https://region1.google-analytics.com; frame-src https://login.smoobu.com; manifest-src 'self'; upgrade-insecure-requests
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Astros gehashte Build-Assets dürfen dauerhaft gecacht werden.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Für HTML und redaktionell stabile Bildnamen gelten bewusst die Cloudflare-
# Pages-Defaults (ETag + max-age=0). So ist ein neues Deployment sofort sichtbar.
