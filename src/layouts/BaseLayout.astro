---
// opsz-Variante: variable optische Größe (Display-Schnitt für große Headlines,
// Text-Schnitt für kleine) — gleiche Dateizahl wie die wght-only-Variante.
import '@fontsource-variable/fraunces/opsz.css';
import frauncesWoff2 from '@fontsource-variable/fraunces/files/fraunces-latin-opsz-normal.woff2?url';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import { site } from '../data/site';
import { getLangFromUrl, useTranslations, alternateLinks, hreflangCode, withBase, withoutBase } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  /** Sprachneutraler Slug für hreflang, z. B. '' (Start) oder 'apartments'. */
  pageKey?: string;
  image?: string;
  /** Zusätzliche JSON-LD-Objekte (z. B. Apartment/Offer je Detailseite). */
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
  /** hreflang-Alternates unterdrücken (für einsprachige Seiten, z. B. DE-Landingpages). */
  noAlternates?: boolean;
}

const { title, description, pageKey = '', image, jsonLd = [], noindex = false, noAlternates = false } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// SEO-Signale verweisen auch im noindex-Staging auf die einzige kanonische
// Produktionsdomain; lokale Assets/Navigation bleiben separat base-aware.
const origin = new URL(site.domain);
// Canonical konsistent MIT Trailing-Slash (Astros Verzeichnis-Ausgabe; die Root
// liefert der Server sonst ohne Slash -> Duplicate-Content-Risiko).
const productionPath = withoutBase(Astro.url.pathname);
const canonicalPath = productionPath.endsWith('/') ? productionPath : `${productionPath}/`;
const canonical = new URL(canonicalPath, origin).href;
const defaultOgImage = new URL(withoutBase(withBase('images/og-default.jpg')), origin).href;
const ogImage = new URL(withoutBase(image ? withBase(image) : withBase('images/og-default.jpg')), origin).href;
const alternates = alternateLinks(pageKey, origin);
// Staging-Deploys (z. B. GitHub Pages) NICHT indexieren – schützt Prod-SEO.
const staging = import.meta.env.PUBLIC_STAGING === 'true';
const robotsNoindex = noindex || staging;

const ogLocaleMap: Record<string, string> = { de: 'de_DE', en: 'en_US', nl: 'nl_NL', da: 'da_DK' };
const ogLocale = ogLocaleMap[lang] ?? 'de_DE';
const localeAlternates = (['de', 'en', 'nl', 'da'] as const).filter((l) => l !== lang).map((l) => ogLocaleMap[l]);

// Stabile, sprachunabhängige Stammdaten: Dieselbe @id darf beim Crawlen nicht
// je nach Unterseite eine andere Beschreibung, ein anderes Bild oder andere
// Ausstattungsnamen erhalten.
const amenityNames = ['WLAN', 'Kostenloser Parkplatz', 'Abschließbare Fahrradgarage', 'Haustiere willkommen'];

// JSON-LD: LodgingBusiness (reguläres Schema, bewusst KEIN Google-VacationRental).
const lodging: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  '@id': new URL(withoutBase(withBase('#lodging')), origin).href,
  name: site.name,
  description: site.tagline,
  url: new URL(withoutBase(withBase('')), origin).href,
  telephone: site.phone,
  email: site.email,
  priceRange: site.priceRange,
  image: defaultOgImage,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    addressCountry: site.address.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng },
  petsAllowed: true,
  checkinTime: site.checkinTime,
  checkoutTime: site.checkoutTime,
  amenityFeature: amenityNames.map((name) => ({
    '@type': 'LocationFeatureSpecification', name, value: true,
  })),
  // Knowledge-Graph-Verknüpfung: Google-Unternehmensprofil (Maps) + Social.
  ...(site.googleProfileUrl ? { hasMap: site.googleProfileUrl } : {}),
  ...(site.facebook || site.instagram || site.googleProfileUrl
    ? { sameAs: [site.facebook, site.instagram, site.googleProfileUrl].filter(Boolean) }
    : {}),
};
const allJsonLd = [lodging, ...jsonLd];
---

<!doctype html>
<html lang={hreflangCode(lang)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    {/* Consent Mode muss vor jedem Google-Tag synchron auf denied stehen.
        Der externe Tag selbst lädt weiterhin erst nach einer aktiven Auswahl. */}
    {site.googleAnalyticsId && (
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
        window.gtag('consent', 'default', {
          analytics_storage: 'denied',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          wait_for_update: 500,
        });
        window.gtag('set', 'ads_data_redaction', true);
        window.__haConsentDefaultSet = true;
      </script>
    )}
    {/* LCP: Headline-Font (Fraunces) vorab laden – self-hosted, kein Google-CDN */}
    <link rel="preload" href={frauncesWoff2} as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {robotsNoindex && <meta name="robots" content="noindex, nofollow" />}

    {/* hreflang-Alternates über alle Sprachen + x-default (außer bei einsprachigen Seiten) */}
    {!noAlternates && alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    {/* Open Graph / Twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale} />
    {localeAlternates.map((l) => <meta property="og:locale:alternate" content={l} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#155e6e" />
    {site.googleSiteVerification && <meta name="google-site-verification" content={site.googleSiteVerification} />}
    <link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />
    <link rel="icon" href={withBase('favicon-32.png')} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={withBase('apple-touch-icon.png')} sizes="180x180" />
    <link rel="manifest" href={withBase('site.webmanifest')} />
    <link rel="sitemap" href={withBase('sitemap-index.xml')} />

    {/* Schriften: Fraunces self-hosted via @fontsource-variable (DSGVO + LCP). */}

    {/* Strukturierte Daten */}
    {allJsonLd.map((obj) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">{t('nav.home')}</a>
    <Header lang={lang} noAlternates={noAlternates} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <ConsentBanner lang={lang} />

    <style>
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--brand-strong);
        color: #fff;
        padding: 0.6rem 1rem;
        z-index: 200;
        border-radius: 0 0 8px 0;
      }
      .skip-link:focus { left: 0; }
    </style>
  </body>
</html>
