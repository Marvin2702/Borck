---
// =========================================================================
// Brücke für die QR-Codes in den Wohnungen: /gast/{slug} versucht die
// Gäste-App zu öffnen (Custom Scheme) und zeigt sonst Hinweise. Die URL ist
// der dauerhafte Vertrag der gedruckten Codes — später übernimmt ein
// Universal/App Link dieselbe Adresse direkt in die App. noindex: interne
// Gäste-Seite, kein Suchtreffer.
// =========================================================================
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const apartments = await getCollection('apartments');
  return apartments.map((a) => ({ params: { slug: a.id }, props: { name: a.data.name, accent: a.data.accent } }));
}

const { name, accent } = Astro.props;
const { slug } = Astro.params;
const appLink = `hausaquamarin://wohnung/${slug}`;
---
<BaseLayout
  title={`Gäste-Info ${name} · ${site.name}`}
  description={`Gäste-App und Infos für die Ferienwohnung ${name} im ${site.name} Büsum.`}
  pageKey={`gast/${slug}`}
  noindex={true}
  noAlternates={true}
>
  <section class="section">
    <div class="container-narrow gast" style={`--a:${accent}`}>
      <p class="eyebrow">Moin in {name}!</p>
      <h1>Deine Gäste-App</h1>
      <p class="lead">
        WLAN, Check-in, Gästemappe, Ausflugstipps und Ebbe &amp; Flut — alles für deinen Aufenthalt, auch offline.
      </p>

      <div class="gast-actions">
        <a class="btn btn--gold btn--lg" href={appLink} data-app-open>Gäste-App öffnen</a>
        {/* TODO nach Store-Release: App-Store- & Play-Store-Badges mit echten Links ergänzen. */}
        <p class="gast-hint">
          App noch nicht installiert? Bis sie im App Store verfügbar ist, helfen dir die ausgedruckten Infos in der
          Wohnung — oder du fragst direkt:
        </p>
        <div class="gast-contact">
          <a class="btn btn--ghost" href={`tel:${site.phone.replace(/\s/g, '')}`}><Icon name="phone" size={16} /> {site.phoneDisplay}</a>
          <a class="btn btn--ghost" href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"><Icon name="chat" size={16} /> WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gast h1 { color: color-mix(in srgb, var(--a) 70%, black); }
  .gast-actions { display: grid; gap: 1rem; justify-items: start; margin-top: 1.5rem; }
  .gast-hint { color: var(--text-muted); max-width: 48ch; margin: 0; }
  .gast-contact { display: flex; gap: 0.7rem; flex-wrap: wrap; }
</style>

<script>
  // Sanfter Auto-Versuch: Wenn die App installiert ist, übernimmt sie direkt.
  const link = document.querySelector<HTMLAnchorElement>('[data-app-open]');
  if (link) setTimeout(() => { window.location.href = link.href; }, 350);
</script>
