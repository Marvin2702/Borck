---
import { useTranslations, localizedPath, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const bookHref = localizedPath('apartments', lang);
const apartmentsHref = localizedPath('apartments', lang);
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-sky"></div>
    <svg class="hero-waves" viewBox="0 0 1440 220" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,96 C240,160 480,40 720,80 C960,120 1200,200 1440,128 L1440,220 L0,220 Z" fill="#7bc0cd" opacity="0.45"/>
      <path d="M0,128 C240,180 480,90 720,120 C960,150 1200,210 1440,160 L1440,220 L0,220 Z" fill="#2a8ca0" opacity="0.5"/>
      <path d="M0,160 C240,200 480,150 720,168 C960,186 1200,220 1440,192 L1440,220 L0,220 Z" fill="#155e6e"/>
    </svg>
  </div>

  <div class="container hero-inner">
    <p class="eyebrow hero-eyebrow">{t('hero.eyebrow')}</p>
    <h1 class="hero-title">{t('hero.title')}</h1>
    <p class="lead hero-sub">{t('hero.subtitle')}</p>
    <div class="hero-cta">
      <a href={bookHref} class="btn btn--gold btn--lg">{t('hero.cta.book')}</a>
      <a href={apartmentsHref} class="btn btn--ghost btn--lg">{t('hero.cta.apartments')}</a>
    </div>
    <div class="hero-trust">
      <span class="stars" aria-hidden="true">★★★★★</span>
      <span>{site.rating.value.toFixed(1)} · {site.rating.count} {t('reviews.source')}s</span>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; overflow: hidden; isolation: isolate; }
  .hero-bg { position: absolute; inset: 0; z-index: -1; }
  .hero-sky {
    position: absolute; inset: 0;
    background:
      radial-gradient(1200px 500px at 80% -10%, rgba(201, 162, 75, 0.18), transparent 60%),
      linear-gradient(165deg, #eaf5f7 0%, #d6ecf0 45%, #bfe1e7 100%);
  }
  .hero-waves { position: absolute; bottom: -1px; left: 0; width: 100%; height: 38%; min-height: 120px; }
  .hero-inner {
    padding-block: clamp(3.5rem, 2rem + 9vw, 8rem) clamp(5rem, 3rem + 8vw, 9rem);
    max-width: 56ch;
  }
  .hero-eyebrow { color: var(--c-aqua-700); }
  .hero-title { color: var(--c-aqua-900); max-width: 18ch; }
  .hero-sub { color: var(--c-ink-700); margin-bottom: 2rem; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .hero-trust {
    margin-top: 2rem; display: inline-flex; align-items: center; gap: 0.6rem;
    color: var(--c-ink-700); font-weight: 600; font-size: 0.95rem;
  }
  .stars { color: var(--c-gold); letter-spacing: 2px; }
</style>
