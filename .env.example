# Öffentliche Build-Konfiguration (Beispielwerte, keine echten IDs)
SITE=https://www.nordsee-buesum-fewo.de
BASE=/
PUBLIC_GA4_ID=
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_WEB3FORMS_ACCESS_KEY=

# Nur serverseitig im Build verwenden; niemals PUBLIC_ voranstellen.
SMOOBU_API_KEY=
SMOOBU_API_SECRET=

# Produktion optional hart auf frische Preis-Snapshots festlegen.
REQUIRE_FRESH_PRICES=false
# Unabhängiger Guard: in Cloudflare-Produktion auf true, sonst nicht setzen.
REQUIRE_INDEXABLE=false

# Nur in Staging-/Preview-Umgebungen aktivieren:
# PUBLIC_STAGING=true
