{
  "expo": {
    "name": "Haus Aquamarin",
    "slug": "haus-aquamarin-gast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hausaquamarin",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "de.nordseebuesumfewo.gast",
      "supportsTablet": false
    },
    "android": {
      "package": "de.nordseebuesumfewo.gast",
      "adaptiveIcon": {
        "backgroundColor": "#faf7f1",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf7f1",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#155e6e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "f1b3e7f0-6ed7-463c-8b26-9be5625b1923"
      }
    }
  }
}
