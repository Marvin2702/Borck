---
import { useTranslations, localizedPath, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const nav = [
  { key: 'apartments', label: t('nav.apartments') },
  { key: 'lage', label: t('nav.location') },
  ...(lang === 'de' ? [{ key: 'reisefuehrer', label: 'Reiseführer' }] : []),
  { key: 'ueber-uns', label: t('nav.about') },
  { key: 'kontakt', label: t('nav.contact') },
];
const legal = [
  { key: 'impressum', label: t('footer.imprint') },
  { key: 'datenschutz', label: t('footer.privacy') },
  { key: 'agb', label: t('footer.terms') },
];
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <span class="brand-name"><span aria-hidden="true">◈</span> {site.name}</span>
      <p class="muted">{t('footer.tagline')}</p>
      <span class="direct-badge">✓ {t('footer.directBadge')}</span>
    </div>

    <nav aria-label={t('footer.nav')}>
      <h3>{t('footer.nav')}</h3>
      <ul>
        {nav.map((i) => <li><a href={localizedPath(i.key, lang)}>{i.label}</a></li>)}
      </ul>
    </nav>

    <div>
      <h3>{t('footer.contact')}</h3>
      <ul class="contact-list">
        <li><a href={`tel:${site.phone.replace(/\s/g, '')}`}>{site.phoneDisplay}</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li>{site.address.postalCode} {site.address.city}</li>
      </ul>
    </div>

    <nav aria-label={t('footer.legal')}>
      <h3>{t('footer.legal')}</h3>
      <ul>
        {/* Rechtstexte zentral auf Deutsch (rechtlich verbindliche Originale). */}
        {legal.map((i) => <li><a href={localizedPath(i.key, 'de')}>{i.label}</a></li>)}
        {site.googleAnalyticsId && (
          <li><button type="button" class="linklike" data-consent-open>{t('footer.cookies')}</button></li>
        )}
      </ul>
      {lang !== 'de' && <p class="legal-note">{t('footer.legalNote')}</p>}
    </nav>
  </div>

  <div class="container footer-bottom">
    <span>© {year} {site.legalName}. {t('footer.rights')}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--c-aqua-900);
    color: rgba(255, 255, 255, 0.82);
    padding-block: clamp(2.5rem, 1.5rem + 3vw, 4rem) 1.5rem;
    margin-top: var(--section-y);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2rem;
  }
  .site-footer h3 {
    color: #fff;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.9rem;
  }
  .site-footer ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
  .site-footer a { color: rgba(255, 255, 255, 0.82); text-decoration: none; }
  .site-footer a:hover { color: #fff; text-decoration: underline; }
  .linklike { background: none; border: 0; padding: 0; font: inherit; color: rgba(255, 255, 255, 0.82); cursor: pointer; text-align: left; }
  .linklike:hover { color: #fff; text-decoration: underline; }
  .legal-note { color: rgba(255, 255, 255, 0.55); font-size: 0.78rem; margin: 0.7rem 0 0; max-width: 26ch; }
  .brand-name { font-family: var(--font-head); font-size: 1.35rem; color: #fff; }
  .brand-name span { color: var(--c-gold); }
  .muted { color: rgba(255, 255, 255, 0.6); margin: 0.6rem 0 1rem; max-width: 34ch; }
  .direct-badge {
    display: inline-block;
    background: rgba(123, 192, 205, 0.18);
    color: var(--c-aqua-100);
    border: 1px solid rgba(123, 192, 205, 0.35);
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
  }
  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
  }
  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }
</style>
