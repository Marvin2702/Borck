---
import { type Lang } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;

const data: Record<Lang, { title: string; items: { l: string; v: string }[] }> = {
  de: {
    title: 'Gut zu wissen',
    items: [
      { l: 'Check-in', v: 'ab 15:00 Uhr (Anreise rund um die Uhr möglich)' },
      { l: 'Check-out', v: 'bis 10:00 Uhr' },
      { l: 'Anzahlung', v: '50 € innerhalb von 7 Tagen (per Überweisung)' },
      { l: 'Restzahlung', v: '30 Tage vor Anreise' },
      { l: 'Stornierung', v: 'bis 30 Tage vorher kostenfrei, danach 50–90 % (eine Ersatzvermietung wird angerechnet)' },
      { l: 'Aufenthalt unter 5 Nächten', v: 'Kurzreise-Zuschlag 85 €' },
      { l: 'Kurtaxe (Gästekarte)', v: '4,00 € Hauptsaison / 2,80 € Nebensaison pro Person & Nacht, wird separat erhoben' },
      { l: 'Hund', v: '46 € pro Buchung (2. Hund 23 €)' },
      { l: 'Bettwäsche / Handtücher', v: '12 € pro Person / 9 € pro Satz' },
      { l: 'Parkplatz & WLAN', v: 'inklusive' },
      { l: 'Nach der Buchung', v: 'persönliche Bestätigung + alle Check-in-Infos vor Anreise' },
    ],
  },
  en: {
    title: 'Good to know',
    items: [
      { l: 'Check-in', v: 'from 3:00 pm (self check-in around the clock)' },
      { l: 'Check-out', v: 'until 10:00 am' },
      { l: 'Deposit', v: '€50 within 7 days (by bank transfer)' },
      { l: 'Balance', v: '30 days before arrival' },
      { l: 'Cancellation', v: 'free up to 30 days before, then 50–90% (any re-letting is credited to you)' },
      { l: 'Stays under 5 nights', v: 'short-stay surcharge €85' },
      { l: 'Visitor’s tax (guest card)', v: '€4.00 high season / €2.80 low season per person & night, charged separately' },
      { l: 'Dog', v: '€46 per booking (2nd dog €23)' },
      { l: 'Bed linen / towels', v: '€12 per person / €9 per set' },
      { l: 'Parking & Wi-Fi', v: 'included' },
      { l: 'After booking', v: 'personal confirmation + all check-in details before arrival' },
    ],
  },
  nl: {
    title: 'Goed om te weten',
    items: [
      { l: 'Check-in', v: 'vanaf 15:00 uur (zelf inchecken de klok rond)' },
      { l: 'Check-out', v: 'tot 10:00 uur' },
      { l: 'Aanbetaling', v: '€ 50 binnen 7 dagen (per overschrijving)' },
      { l: 'Restbetaling', v: '30 dagen voor aankomst' },
      { l: 'Annulering', v: 'gratis tot 30 dagen vooraf, daarna 50–90% (herverhuur wordt verrekend)' },
      { l: 'Verblijf korter dan 5 nachten', v: 'toeslag korte reis € 85' },
      { l: 'Toeristenbelasting (gastenkaart)', v: '€ 4,00 hoogseizoen / € 2,80 laagseizoen per persoon per nacht, apart afgerekend' },
      { l: 'Hond', v: '€ 46 per boeking (2e hond € 23)' },
      { l: 'Beddengoed / handdoeken', v: '€ 12 p.p. / € 9 per set' },
      { l: 'Parkeerplaats & wifi', v: 'inbegrepen' },
      { l: 'Na de boeking', v: 'persoonlijke bevestiging + alle check-in-info vóór aankomst' },
    ],
  },
  da: {
    title: 'Godt at vide',
    items: [
      { l: 'Check-in', v: 'fra kl. 15:00 (selv-check-in døgnet rundt)' },
      { l: 'Check-out', v: 'indtil kl. 10:00' },
      { l: 'Depositum', v: '50 € inden 7 dage (via bankoverførsel)' },
      { l: 'Restbetaling', v: '30 dage før ankomst' },
      { l: 'Afbestilling', v: 'gratis indtil 30 dage før, derefter 50–90 % (genudlejning modregnes)' },
      { l: 'Ophold under 5 nætter', v: 'tillæg for kort ophold 85 €' },
      { l: 'Kurafgift (gæstekort)', v: '4,00 € højsæson / 2,80 € lavsæson pr. person pr. nat, opkræves separat' },
      { l: 'Hund', v: '46 € pr. booking (2. hund 23 €)' },
      { l: 'Sengetøj / håndklæder', v: '12 € pr. pers. / 9 € pr. sæt' },
      { l: 'Parkering & wi-fi', v: 'inkluderet' },
      { l: 'Efter booking', v: 'personlig bekræftelse + alle check-in-oplysninger før ankomst' },
    ],
  },
};
const d = data[lang];
---
<section class="section gtw">
  <div class="container-narrow">
    <h2>{d.title}</h2>
    <div class="gtw-grid">
      {d.items.map((i) => (
        <div class="gtw-row">
          <span class="gtw-l">{i.l}</span>
          <span class="gtw-v">{i.v}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gtw-grid { margin-top: 1.4rem; display: grid; gap: 0; border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; }
  .gtw-row { display: grid; grid-template-columns: minmax(140px, 0.6fr) 1fr; gap: 1rem; padding: 0.85rem 1.2rem; }
  .gtw-row:nth-child(odd) { background: var(--c-sand-50); }
  .gtw-l { font-weight: 600; color: var(--brand-strong); }
  .gtw-v { color: var(--text); font-variant-numeric: tabular-nums; }
  @media (max-width: 520px) { .gtw-row { grid-template-columns: 1fr; gap: 0.2rem; } }
</style>
