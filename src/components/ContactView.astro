---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from './Img.astro';
import Icon from './Icon.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const waText = encodeURIComponent(t('contact.whatsapp.msg'));
const title = `${t('contact.title')} · ${site.name} Büsum`;
// Apartment-Auswahl fürs Formular (buildtime aus der Collection).
const apartments = (await getCollection('apartments')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title={title} description={t('contact.subtitle')} pageKey="kontakt">
  <section class="section">
    <div class="container-narrow">
      <p class="eyebrow">{t('site.tagline')}</p>
      <h1>{t('contact.title')}</h1>
      <p class="lead">{t('contact.subtitle')}</p>

      <div class="contact-grid">
        <a class="contact-card" href={`tel:${site.phone.replace(/\s/g, '')}`}>
          <span class="ci"><Icon name="phone" size={22} /></span>
          <span class="cl">{t('contact.phone')}</span>
          <strong>{site.phoneDisplay}</strong>
        </a>
        <a class="contact-card" href={`https://wa.me/${site.whatsapp}?text=${waText}`} target="_blank" rel="noopener">
          <span class="ci"><Icon name="chat" size={22} /></span>
          <span class="cl">{t('contact.whatsapp')}</span>
          <strong>{site.phoneDisplay}</strong>
        </a>
        <a class="contact-card" href={`mailto:${site.email}`}>
          <span class="ci"><Icon name="mail" size={22} /></span>
          <span class="cl">{t('contact.email')}</span>
          <strong>{site.email}</strong>
        </a>
        <div class="contact-card">
          <span class="ci"><Icon name="pin" size={22} /></span>
          <span class="cl">{site.name}</span>
          <strong>{site.address.postalCode} {site.address.city}</strong>
        </div>
      </div>

      <form
        class="contact-form"
        data-contact-form
        action="https://api.web3forms.com/submit"
        method="POST"
        data-haskey={site.formAccessKey ? '1' : '0'}
        data-email={site.email}
        data-success={t('form.success')}
        data-error={t('form.error')}
        data-mailtohint={`${t('form.mailtoHint')} ${site.email} · ${site.phoneDisplay}`}
      >
        <input type="hidden" name="access_key" value={site.formAccessKey} />
        <input type="hidden" name="subject" value={`Anfrage über ${site.name} Website`} />
        <input type="hidden" name="from_name" value={site.name} />
        <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />
        <div class="form-head">
          <span class="form-portrait" aria-hidden="true">
            <Img src="/images/iris-mia.jpg" alt="" width={112} height={112} loading="lazy" sizes="56px" />
          </span>
          <div>
            <h2>{t('form.title')}</h2>
            <p class="form-greeting">{t('form.greeting')}</p>
          </div>
        </div>
        <div class="form-row">
          <label>{t('form.name')}<input type="text" name="name" required autocomplete="name" /></label>
          <label>{t('contact.email')}<input type="email" name="email" required autocomplete="email" /></label>
        </div>
        <div class="form-row">
          <label>{t('form.arrival')}<input type="date" name="arrival" autocomplete="off" /></label>
          <label>{t('form.departure')}<input type="date" name="departure" autocomplete="off" /></label>
        </div>
        <div class="form-row">
          <label>{t('form.apartment')}
            <select name="apartment">
              <option value="">{t('form.apartmentAny')}</option>
              {apartments.map((a) => <option value={a.data.name}>{a.data.name}</option>)}
            </select>
          </label>
          <label>{t('apartments.persons')}<input type="number" name="guests" min="1" max="6" inputmode="numeric" /></label>
        </div>
        <label>{t('form.message')}<textarea name="message" rows="4" required></textarea></label>
        <button type="submit" class="btn btn--gold">{t('form.send')}</button>
        <p class="form-status" data-form-status role="status" aria-live="polite"></p>
      </form>

      <figure class="contact-image">
        <Img src="/images/kontakt-maritim.jpg" alt="Haus Aquamarin in Büsum"
             width={1200} height={600} loading="lazy" sizes="100vw" />
      </figure>
      <p class="addr-line">{site.name} · {site.address.street} · {site.address.postalCode} {site.address.city}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); margin: 2rem 0; }
  .contact-card {
    display: grid; gap: 0.25rem;
    background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 1.3rem 1.4rem;
    text-decoration: none; color: var(--text); box-shadow: var(--shadow-sm);
  }
  a.contact-card:hover { border-color: var(--c-aqua-300); transform: translateY(-2px); }
  .ci { color: var(--brand); }
  .cl { color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .contact-card strong { color: var(--brand-strong); font-size: 1.1rem; }
  .contact-image { margin: 1.5rem 0 0.6rem; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
  /* :global nötig: <img> kommt aus Img.astro und trägt die Scope-Klasse nicht. */
  .contact-image :global(img) { width: 100%; height: auto; display: block; object-fit: cover; aspect-ratio: 2 / 1; }
  .addr-line { color: var(--text-muted); text-align: center; }

  .contact-form {
    margin-top: 2.5rem; background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius-lg); padding: clamp(1.2rem, 0.8rem + 2vw, 2rem);
    box-shadow: var(--shadow-sm); display: grid; gap: 1rem;
  }
  .contact-form h2 { margin: 0; font-size: 1.5rem; }
  .form-head { display: flex; align-items: center; gap: 0.9rem; }
  .form-portrait { flex: none; width: 56px; height: 56px; border-radius: 999px; overflow: hidden; box-shadow: var(--shadow-sm); }
  .form-portrait :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .form-greeting { margin: 0.15rem 0 0; color: var(--text-muted); font-family: var(--font-head); font-style: italic; font-size: 1.02rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-form label { display: grid; gap: 0.35rem; font-size: 0.9rem; font-weight: 600; color: var(--text); }
  .contact-form input, .contact-form textarea, .contact-form select {
    font: inherit; font-weight: 400; padding: 0.7rem 0.85rem;
    border: 1px solid var(--line); border-radius: 10px; background: var(--c-sand-50); color: var(--text);
    min-height: 44px;
  }
  .contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus { outline: 2px solid var(--brand); outline-offset: 1px; border-color: transparent; }
  .contact-form button { justify-self: start; }
  .hp { position: absolute; left: -9999px; }
  .form-status { margin: 0; font-weight: 600; }
  .form-status.is-ok { color: var(--c-deich-700); }
  .form-status.is-err { color: #a52a3a; }
  @media (max-width: 600px) {
    .contact-grid, .form-row { grid-template-columns: 1fr; }
    .contact-form button { justify-self: stretch; width: 100%; }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  if (form) {
    const status = form.querySelector<HTMLElement>('[data-form-status]');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      // Ohne Web3Forms-Key: mailto-Fallback (öffnet das E-Mail-Programm).
      if (form.dataset.haskey !== '1') {
        const subject = encodeURIComponent('Anfrage Ferienwohnung Büsum');
        const body = encodeURIComponent(
          `Name: ${data.get('name')}\nE-Mail: ${data.get('email')}\n` +
          `Anreise: ${data.get('arrival')}\nAbreise: ${data.get('departure')}\n` +
          `Apartment: ${data.get('apartment') || '-'}\nPersonen: ${data.get('guests')}\n\n${data.get('message')}`
        );
        window.location.href = `mailto:${form.dataset.email}?subject=${subject}&body=${body}`;
        // Ehrliches Feedback: ohne eingerichtetes Mail-Programm passiert sonst
        // scheinbar nichts — Hinweis mit direkter Kontaktmöglichkeit anzeigen.
        if (status) { status.textContent = form.dataset.mailtohint || ''; status.className = 'form-status is-ok'; }
        return;
      }
      if (status) { status.textContent = '…'; status.className = 'form-status'; }
      try {
        const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('bad');
        form.reset();
        if (status) { status.textContent = form.dataset.success || ''; status.className = 'form-status is-ok'; }
      } catch {
        if (status) { status.textContent = form.dataset.error || ''; status.className = 'form-status is-err'; }
      }
    });
  }
</script>
