---
import { localizedPath, type Lang } from '../i18n/utils';
import { site } from '../data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;

type ConsentCopy = {
  title: string;
  intro: string;
  more: string;
  necessary: string;
  necessaryText: string;
  analytics: string;
  analyticsText: string;
  marketing: string;
  marketingText: string;
  reject: string;
  save: string;
  acceptAll: string;
};

const txt: Record<Lang, ConsentCopy> = {
  de: {
    title: 'Deine Cookie-Auswahl',
    intro: 'Du entscheidest, welche optionalen Dienste wir verwenden dürfen.',
    more: 'Datenschutz',
    necessary: 'Erforderlich',
    necessaryText: 'Speichert nur deine Auswahl und ist immer aktiv.',
    analytics: 'Statistik',
    analyticsText: 'Hilft uns datensparsam zu verstehen, welche Seiten und Buchungswege genutzt werden.',
    marketing: 'Marketing',
    marketingText: 'Erlaubt die Messung und Personalisierung zukünftiger Werbekampagnen.',
    reject: 'Nur erforderlich',
    save: 'Auswahl speichern',
    acceptAll: 'Alle akzeptieren',
  },
  en: {
    title: 'Your cookie choices',
    intro: 'You decide which optional services we may use.',
    more: 'Privacy',
    necessary: 'Necessary',
    necessaryText: 'Only stores your choice and is always active.',
    analytics: 'Analytics',
    analyticsText: 'Helps us understand in aggregate which pages and booking paths are used.',
    marketing: 'Marketing',
    marketingText: 'Allows measurement and personalisation of future advertising campaigns.',
    reject: 'Necessary only',
    save: 'Save selection',
    acceptAll: 'Accept all',
  },
  nl: {
    title: 'Jouw cookiekeuze',
    intro: 'Je bepaalt welke optionele diensten we mogen gebruiken.',
    more: 'Privacy',
    necessary: 'Noodzakelijk',
    necessaryText: 'Slaat alleen je keuze op en is altijd actief.',
    analytics: 'Statistieken',
    analyticsText: 'Helpt ons op hoofdlijnen te begrijpen welke pagina’s en boekingsroutes worden gebruikt.',
    marketing: 'Marketing',
    marketingText: 'Staat meting en personalisatie van toekomstige advertentiecampagnes toe.',
    reject: 'Alleen noodzakelijk',
    save: 'Keuze opslaan',
    acceptAll: 'Alles accepteren',
  },
  da: {
    title: 'Dit cookievalg',
    intro: 'Du bestemmer, hvilke valgfrie tjenester vi må bruge.',
    more: 'Privatliv',
    necessary: 'Nødvendige',
    necessaryText: 'Gemmer kun dit valg og er altid aktivt.',
    analytics: 'Statistik',
    analyticsText: 'Hjælper os på aggregeret niveau med at forstå, hvilke sider og bookingveje der bruges.',
    marketing: 'Marketing',
    marketingText: 'Tillader måling og personalisering af fremtidige annoncekampagner.',
    reject: 'Kun nødvendige',
    save: 'Gem valg',
    acceptAll: 'Acceptér alle',
  },
};
const c = txt[lang];
const privacyHref = localizedPath('datenschutz', 'de');
---

<div
  class="consent"
  data-consent
  data-ga={site.googleAnalyticsId}
  data-language={lang}
  hidden
  role="dialog"
  aria-labelledby="consent-title"
  aria-describedby="consent-intro"
>
  <div class="consent-copy">
    <h2 id="consent-title">{c.title}</h2>
    <p id="consent-intro">{c.intro} <a href={privacyHref}>{c.more}</a></p>
  </div>

  <fieldset class="consent-options">
    <legend class="sr-only">{c.title}</legend>
    <label class="consent-option is-required">
      <input type="checkbox" checked disabled />
      <span><strong>{c.necessary}</strong><small>{c.necessaryText}</small></span>
    </label>
    <label class="consent-option">
      <input type="checkbox" data-consent-analytics />
      <span><strong>{c.analytics}</strong><small>{c.analyticsText}</small></span>
    </label>
    <label class="consent-option">
      <input type="checkbox" data-consent-marketing />
      <span><strong>{c.marketing}</strong><small>{c.marketingText}</small></span>
    </label>
  </fieldset>

  <div class="consent-actions">
    <button type="button" class="btn btn--ghost" data-consent-reject>{c.reject}</button>
    <button type="button" class="btn btn--ghost" data-consent-save>{c.save}</button>
    <button type="button" class="btn btn--gold" data-consent-all>{c.acceptAll}</button>
  </div>
</div>

<style>
  .consent {
    position: fixed; bottom: 1rem; left: 1rem; right: 1rem; z-index: 250;
    width: min(760px, calc(100% - 2rem)); margin-inline: auto;
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg); padding: clamp(1rem, 0.8rem + 1vw, 1.4rem);
    display: grid; gap: 1rem;
  }
  .consent[hidden] { display: none; }
  .consent h2 { margin: 0; font-size: 1.35rem; }
  .consent p { margin: 0.2rem 0 0; font-size: 0.92rem; color: var(--text-muted); }
  .consent a { color: var(--brand); font-weight: 650; }
  .consent-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.65rem; margin: 0; padding: 0; border: 0; }
  .consent-option {
    display: flex; align-items: flex-start; gap: 0.65rem; padding: 0.75rem;
    border: 1px solid var(--line); border-radius: 10px; background: var(--c-sand-50);
    cursor: pointer;
  }
  .consent-option.is-required { cursor: default; }
  .consent-option input { flex: none; width: 18px; height: 18px; margin-top: 0.1rem; accent-color: var(--brand); }
  .consent-option span { display: grid; gap: 0.15rem; }
  .consent-option strong { color: var(--text); font-size: 0.9rem; }
  .consent-option small { color: var(--text-muted); font-size: 0.76rem; line-height: 1.35; }
  .consent-actions { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 0.6rem; }
  .consent .btn { min-height: 44px; padding: 0.55rem 1rem; font-size: 0.86rem; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  @media (max-width: 680px) {
    .consent { bottom: 0.5rem; width: min(100% - 1rem, 540px); max-height: calc(100svh - 1rem); overflow-y: auto; }
    .consent-options { grid-template-columns: 1fr; }
    .consent-actions { display: grid; grid-template-columns: 1fr 1fr; }
    .consent-actions .btn { width: 100%; justify-content: center; }
    .consent-actions [data-consent-save] { grid-column: 1 / -1; grid-row: 1; }
  }
</style>

<script>
  type ConsentChoice = {
    version: 2;
    analytics: boolean;
    marketing: boolean;
    updatedAt: string;
  };

  type SafeEventName =
    | 'availability_search'
    | 'view_booking_widget'
    | 'iframe_engagement'
    | 'view_apartment'
    | 'select_apartment'
    | 'begin_booking'
    | 'generate_lead'
    | 'contact_phone'
    | 'contact_whatsapp'
    | 'booking_complete';

  const STORAGE_KEY = 'ha-consent-v2';
  const LEGACY_KEY = 'ha-consent-stats';
  const el = document.querySelector<HTMLElement>('[data-consent]');
  const gaId = el?.dataset.ga || '';
  const pageLanguage = el?.dataset.language || document.documentElement.lang || 'de';
  const analyticsInput = el?.querySelector<HTMLInputElement>('[data-consent-analytics]');
  const marketingInput = el?.querySelector<HTMLInputElement>('[data-consent-marketing]');
  const w = window as any;

  const ALLOWED_EVENTS = new Set<SafeEventName>([
    'availability_search',
    'view_booking_widget',
    'iframe_engagement',
    'view_apartment',
    'select_apartment',
    'begin_booking',
    'generate_lead',
    'contact_phone',
    'contact_whatsapp',
    'booking_complete',
  ]);
  const SAFE_PARAM_KEYS = new Set([
    'apartment_id',
    'cta_location',
    'form_id',
    'interaction_type',
    'link_type',
    'method',
    'page_language',
    'widget_type',
  ]);

  function ensureConsentApi() {
    if (!gaId) return;
    w.dataLayer = w.dataLayer || [];
    w.gtag = w.gtag || function () { w.dataLayer.push(arguments); };
    // BaseLayout setzt diesen Default synchron im Head. Der Fallback hält das
    // Teil auch bei isolierter Verwendung sicher und läuft vor jedem Google-Tag.
    if (!w.__haConsentDefaultSet) {
      w.gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
      w.gtag('set', 'ads_data_redaction', true);
      w.__haConsentDefaultSet = true;
    }
  }

  function safeStorageGet(key: string) {
    try { return localStorage.getItem(key); } catch { return null; }
  }

  function safeStorageSet(key: string, value: string) {
    try { localStorage.setItem(key, value); } catch { /* Consent wirkt trotzdem für diese Seite. */ }
  }

  function safeStorageRemove(key: string) {
    try { localStorage.removeItem(key); } catch { /* noop */ }
  }

  function readChoice(): ConsentChoice | null {
    const raw = safeStorageGet(STORAGE_KEY);
    if (raw) {
      try {
        const parsed = JSON.parse(raw);
        if (parsed?.version === 2 && typeof parsed.analytics === 'boolean' && typeof parsed.marketing === 'boolean') {
          const choice: ConsentChoice = {
            version: 2,
            analytics: parsed.analytics,
            marketing: parsed.marketing,
            updatedAt: typeof parsed.updatedAt === 'string' ? parsed.updatedAt : new Date(0).toISOString(),
          };
          safeStorageRemove(LEGACY_KEY);
          return choice;
        }
      } catch { /* Ungültige/alte Auswahl wird erneut abgefragt. */ }
    }

    // Bestehende Statistik-Auswahl datensparsam migrieren; Marketing bleibt aus.
    const legacy = safeStorageGet(LEGACY_KEY);
    if (legacy === 'granted' || legacy === 'denied') {
      const migrated: ConsentChoice = {
        version: 2,
        analytics: legacy === 'granted',
        marketing: false,
        updatedAt: new Date().toISOString(),
      };
      safeStorageSet(STORAGE_KEY, JSON.stringify(migrated));
      safeStorageRemove(LEGACY_KEY);
      return migrated;
    }
    return null;
  }

  function clearAnalyticsCookies() {
    const names = document.cookie.split(';').map((part) => part.split('=')[0]?.trim()).filter(Boolean);
    const host = location.hostname;
    const domains = new Set([host, `.${host}`]);
    // GA setzt auf www üblicherweise ein Cookie an der Parent-Domain. Eine
    // Ableitung über den letzten Punkt wäre für Public Suffixes (github.io)
    // falsch, deshalb nur die bekannte Produktionsdomain ergänzen.
    if (host === 'www.nordsee-buesum-fewo.de' || host === 'nordsee-buesum-fewo.de') {
      domains.add('nordsee-buesum-fewo.de');
      domains.add('.nordsee-buesum-fewo.de');
    }
    for (const name of names) {
      if (!name || !/^_(?:ga|gid|gat|gcl_)/.test(name)) continue;
      document.cookie = `${name}=; Max-Age=0; Path=/; SameSite=Lax`;
      domains.forEach((domain) => {
        document.cookie = `${name}=; Max-Age=0; Path=/; Domain=${domain}; SameSite=Lax`;
      });
    }
  }

  function loadGoogleTag(marketing: boolean) {
    if (!gaId) return;
    w[`ga-disable-${gaId}`] = false;
    if (w.__haGaLoaded) {
      w.gtag('config', gaId, {
        send_page_view: false,
        allow_google_signals: marketing,
        allow_ad_personalization_signals: marketing,
        linker: { domains: ['nordsee-buesum-fewo.de', 'booking.smoobu.com', 'login.smoobu.com'] },
      });
      return;
    }

    w.__haGaLoaded = true;
    const script = document.createElement('script');
    script.id = 'ha-google-tag';
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(gaId)}`;
    script.referrerPolicy = 'strict-origin-when-cross-origin';
    document.head.appendChild(script);
    w.gtag('js', new Date());
    w.gtag('config', gaId, {
      allow_google_signals: marketing,
      allow_ad_personalization_signals: marketing,
      linker: { domains: ['nordsee-buesum-fewo.de', 'booking.smoobu.com', 'login.smoobu.com'] },
    });
  }

  function sanitiseParams(params: Record<string, unknown> = {}) {
    const safe: Record<string, string | number | boolean> = { page_language: pageLanguage.slice(0, 8) };
    for (const [key, value] of Object.entries(params)) {
      if (!SAFE_PARAM_KEYS.has(key)) continue;
      if (typeof value === 'boolean' || (typeof value === 'number' && Number.isFinite(value))) safe[key] = value;
      else if (typeof value === 'string') safe[key] = value.replace(/\s+/g, ' ').trim().slice(0, 80);
    }
    return safe;
  }

  w.haTrack = function (eventName: SafeEventName, params: Record<string, unknown> = {}) {
    if (!gaId || !w.__haAnalyticsGranted || !ALLOWED_EVENTS.has(eventName) || typeof w.gtag !== 'function') return false;
    w.gtag('event', eventName, sanitiseParams(params));
    return true;
  };

  function applyChoice(choice: ConsentChoice, persist = false) {
    if (!gaId) return;
    ensureConsentApi();
    w.__haConsentChoice = { analytics: choice.analytics, marketing: choice.marketing };
    w.__haAnalyticsGranted = choice.analytics;
    w[`ga-disable-${gaId}`] = !choice.analytics;

    w.gtag('consent', 'update', {
      analytics_storage: choice.analytics ? 'granted' : 'denied',
      ad_storage: choice.marketing ? 'granted' : 'denied',
      ad_user_data: choice.marketing ? 'granted' : 'denied',
      ad_personalization: choice.marketing ? 'granted' : 'denied',
    });

    if (choice.analytics) loadGoogleTag(choice.marketing);
    else clearAnalyticsCookies();

    if (persist) safeStorageSet(STORAGE_KEY, JSON.stringify(choice));
    document.dispatchEvent(new CustomEvent('ha:consentchange', {
      detail: { analytics: choice.analytics, marketing: choice.marketing },
    }));
    if (choice.analytics) document.dispatchEvent(new Event('ha:analytics-ready'));
  }

  function setControls(choice: ConsentChoice | null) {
    if (analyticsInput) analyticsInput.checked = choice?.analytics ?? false;
    if (marketingInput) marketingInput.checked = choice?.marketing ?? false;
  }

  function openConsent() {
    if (!el || !gaId) return;
    setControls(readChoice());
    el.hidden = false;
    requestAnimationFrame(() => el.querySelector<HTMLButtonElement>('[data-consent-reject]')?.focus());
  }

  function saveChoice(analytics: boolean, marketing: boolean) {
    const choice: ConsentChoice = { version: 2, analytics, marketing, updatedAt: new Date().toISOString() };
    setControls(choice);
    applyChoice(choice, true);
    if (el) el.hidden = true;
  }

  ensureConsentApi();
  const storedChoice = gaId ? readChoice() : null;
  if (storedChoice) {
    setControls(storedChoice);
    applyChoice(storedChoice);
  } else if (gaId && el) {
    el.hidden = false;
  }

  el?.querySelector('[data-consent-reject]')?.addEventListener('click', () => saveChoice(false, false));
  el?.querySelector('[data-consent-save]')?.addEventListener('click', () => {
    saveChoice(analyticsInput?.checked ?? false, marketingInput?.checked ?? false);
  });
  el?.querySelector('[data-consent-all]')?.addEventListener('click', () => saveChoice(true, true));
  document.querySelectorAll<HTMLElement>('[data-consent-open]').forEach((button) => {
    button.addEventListener('click', openConsent);
  });

  function ctaLocation(anchor: HTMLAnchorElement) {
    if (anchor.dataset.trackLocation) return anchor.dataset.trackLocation;
    if (anchor.closest('header')) return 'header';
    if (anchor.closest('footer')) return 'footer';
    if (anchor.closest('.sticky-cta')) return 'sticky';
    if (anchor.closest('.apt-actions')) return 'apartment_card';
    if (anchor.closest('.detail-aside')) return 'apartment_detail';
    if (anchor.closest('#buchung, .booking')) return 'booking_widget';
    if (anchor.closest('.contact-card')) return 'contact_card';
    return 'content';
  }

  function apartmentIdFrom(anchor?: HTMLAnchorElement | null) {
    const fromData = anchor?.dataset.trackApartment
      || anchor?.dataset.apartmentId
      || anchor?.closest<HTMLElement>('[data-apartment-id]')?.dataset.apartmentId;
    if (fromData && /^[a-z0-9-]+$/i.test(fromData)) return fromData;
    if (!anchor) return '';
    try {
      const url = new URL(anchor.href, location.href);
      const queryId = url.searchParams.get('apartmentId');
      if (queryId && /^\d+$/.test(queryId)) return queryId;
      const match = url.pathname.match(/\/apartments\/([^/]+)/i);
      const slug = match?.[1] ? decodeURIComponent(match[1]) : '';
      return /^[a-z0-9-]+$/i.test(slug) ? slug : '';
    } catch { return ''; }
  }

  let apartmentPageTracked = false;
  function trackApartmentPage() {
    if (apartmentPageTracked) return;
    const match = location.pathname.match(/\/apartments\/([^/]+)\/?$/i);
    const apartmentId = match?.[1] ? decodeURIComponent(match[1]) : '';
    if (!/^[a-z0-9-]+$/i.test(apartmentId)) return;
    apartmentPageTracked = w.haTrack('view_apartment', { apartment_id: apartmentId });
  }

  document.addEventListener('click', (event) => {
    const anchor = (event.target as Element | null)?.closest?.('a[href]') as HTMLAnchorElement | null;
    if (!anchor) return;
    const href = anchor.href;
    const context = ctaLocation(anchor);
    const apartmentId = apartmentIdFrom(anchor);
    const params = { cta_location: context, ...(apartmentId ? { apartment_id: apartmentId } : {}) };

    const events = new Set<SafeEventName>();
    const explicit = anchor.dataset.trackEvent as SafeEventName | undefined;
    if (explicit && ALLOWED_EVENTS.has(explicit)) events.add(explicit);
    if (href.startsWith('tel:')) {
      events.add('contact_phone');
      events.forEach((name) => w.haTrack(name, { cta_location: context, link_type: 'telephone' }));
      return;
    }
    if (href.includes('wa.me/')) {
      events.add('contact_whatsapp');
      events.forEach((name) => w.haTrack(name, { cta_location: context, link_type: 'whatsapp' }));
      return;
    }

    const isSmoobu = href.includes('booking.smoobu.com') || href.includes('login.smoobu.com');
    const selectsApartment = Boolean(apartmentId) && (isSmoobu || anchor.matches('.apt-book, [data-select-apartment]'));
    if (selectsApartment) events.add('select_apartment');
    if (isSmoobu || anchor.matches('[data-begin-booking]')) {
      events.add('begin_booking');
    }
    events.forEach((name) => w.haTrack(name, params));
  }, { capture: true });

  const currentApartmentId = () => {
    const fromDetail = document.querySelector<HTMLElement>('[data-apartment-detail]')?.dataset.apartmentId;
    if (fromDetail && /^[a-z0-9-]+$/i.test(fromDetail)) return fromDetail;
    const match = location.pathname.match(/\/apartments\/([^/]+)\/?$/i);
    const slug = match?.[1] ? decodeURIComponent(match[1]) : '';
    return /^[a-z0-9-]+$/i.test(slug) ? slug : '';
  };
  const visibleBookingSections = new Set<HTMLElement>();
  const trackedBookingSections = new WeakSet<HTMLElement>();
  const trackBookingViews = () => {
    visibleBookingSections.forEach((section) => {
      if (trackedBookingSections.has(section)) return;
      const mode = section.dataset.bookingMode || section.querySelector<HTMLElement>('.booking-embed')?.dataset.mode || 'apartment';
      const apartmentId = currentApartmentId();
      if (w.haTrack('view_booking_widget', {
        widget_type: mode === 'all' ? 'all_apartments' : 'apartment',
        ...(apartmentId ? { apartment_id: apartmentId } : {}),
      })) trackedBookingSections.add(section);
    });
  };
  const bookingSections = document.querySelectorAll<HTMLElement>('[data-booking-section], #buchung');
  if (bookingSections.length && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const section = entry.target as HTMLElement;
        if (entry.isIntersecting) visibleBookingSections.add(section);
        else visibleBookingSections.delete(section);
      });
      trackBookingViews();
    }, { threshold: 0.2 });
    bookingSections.forEach((section) => observer.observe(section));
  } else {
    bookingSections.forEach((section) => visibleBookingSections.add(section));
    trackBookingViews();
  }

  let iframeHovered = false;
  let iframeEngagementTracked = false;
  let bookingBeginTracked = false;
  document.addEventListener('click', (event) => {
    const activate = (event.target as Element | null)?.closest?.('[data-booking-activate]') as HTMLElement | null;
    if (!activate || iframeEngagementTracked) return;
    const mode = activate.closest<HTMLElement>('[data-booking-section]')?.dataset.bookingMode || 'apartment';
    iframeEngagementTracked = w.haTrack('iframe_engagement', {
      widget_type: mode === 'all' ? 'all_apartments' : 'apartment',
      interaction_type: 'activate',
    });
  }, { capture: true });
  document.addEventListener('pointerover', (event) => {
    const target = event.target;
    if (target instanceof HTMLIFrameElement && target.closest('#buchung, .booking-embed')) iframeHovered = true;
  });
  document.addEventListener('pointerout', (event) => {
    const target = event.target;
    if (target instanceof HTMLIFrameElement && target.closest('#buchung, .booking-embed')) iframeHovered = false;
  });
  window.addEventListener('blur', () => {
    setTimeout(() => {
      const active = document.activeElement;
      const isBookingFrame = active instanceof HTMLIFrameElement && Boolean(active.closest('#buchung, .booking-embed'));
      const hoveredWhileVisible = iframeHovered && document.visibilityState === 'visible';
      if (hoveredWhileVisible || isBookingFrame) {
        if (!iframeEngagementTracked) {
          iframeEngagementTracked = w.haTrack('iframe_engagement', {
            widget_type: 'smoobu',
            interaction_type: 'focus',
          });
        }
        if (!bookingBeginTracked) {
          const apartmentId = currentApartmentId();
          bookingBeginTracked = w.haTrack('begin_booking', {
            cta_location: 'booking_widget',
            widget_type: 'smoobu',
            ...(apartmentId ? { apartment_id: apartmentId } : {}),
          });
        }
      }
    }, 0);
  });

  window.addEventListener('message', (event) => {
    if (!['https://login.smoobu.com', 'https://booking.smoobu.com'].includes(event.origin)) return;
    if (event.data?.type !== 'ha:booking_complete') return;
    const comesFromBookingFrame = Array.from(document.querySelectorAll('iframe'))
      .some((frame) => frame.contentWindow === event.source);
    if (!comesFromBookingFrame) return;
    let alreadyTracked = false;
    try { alreadyTracked = sessionStorage.getItem('ha-booking-complete') === '1'; } catch { /* noop */ }
    if (alreadyTracked) return;
    if (w.haTrack('booking_complete', { method: 'smoobu', widget_type: 'smoobu' })) {
      try { sessionStorage.setItem('ha-booking-complete', '1'); } catch { /* noop */ }
    }
  });

  document.addEventListener('ha:analytics-ready', () => {
    trackApartmentPage();
    trackBookingViews();
  });
  trackApartmentPage();
  trackBookingViews();
</script>
