---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ApartmentCard from './ApartmentCard.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import Faq from './Faq.astro';
import ThemeLinks from './ThemeLinks.astro';
import Icon from './Icon.astro';
import BookingWidget from './BookingWidget.astro';
import { useTranslations, localizedPath, withoutBase, type Lang } from '../i18n/utils';
import { site } from '../data/site';
import { trExtra, trUnit } from '../data/extras-i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const apartments = (await getCollection('apartments')).sort((a, b) => a.data.order - b.data.order);

const title = `${t('meta.apartmentsTitle')} · ${site.name}`;
const description = t('meta.apartmentsDesc');
const origin = new URL(site.domain);
const apartmentsListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: t('apartments.title'),
  numberOfItems: apartments.length,
  itemListElement: apartments.map((apartment, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: apartment.data.name,
    url: new URL(withoutBase(localizedPath(`apartments/${apartment.id}`, lang)), origin).href,
  })),
};
---
<BaseLayout title={title} description={description} pageKey="apartments" jsonLd={[apartmentsListLd]}>
  <section class="section page-head">
    <div class="container-narrow text-center">
      <Breadcrumbs
        lang={lang}
        align="center"
        items={[{ label: t('apartments.title'), href: localizedPath('apartments', lang) }]}
      />
      <p class="eyebrow">{t('site.tagline')}</p>
      <h1>{t('apartments.title')}</h1>
      <p class="lead mx-auto">{t('apartments.subtitle')}</p>
    </div>
  </section>

  <BookingWidget lang={lang} mode="all" />

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="apt-filter" role="group" aria-label={t('filter.label')}>
        <div class="filter-group" data-filter="persons">
          <span class="filter-legend">{t('apartments.persons')}</span>
          <button type="button" class="filter-pill is-active" data-value="0">{t('filter.all')}</button>
          <button type="button" class="filter-pill" data-value="2">2+</button>
          <button type="button" class="filter-pill" data-value="4">4+</button>
          <button type="button" class="filter-pill" data-value="5">5</button>
        </div>
        <div class="filter-toggles">
          <button type="button" class="filter-pill" data-toggle="dog" aria-pressed="false"><Icon name="paw" size={15} /> {t('filter.dog')}</button>
          <button type="button" class="filter-pill" data-toggle="seaview" aria-pressed="false"><Icon name="wave" size={15} /> {t('filter.seaview')}</button>
        </div>
      </div>

      <div class="apt-grid" data-apt-grid>
        {apartments.map((a) => <ApartmentCard apartment={a} lang={lang} />)}
      </div>
      <button type="button" class="filter-none" data-filter-none hidden>{t('filter.none')}</button>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <h2>{t('apartments.extrasTitle')}</h2>
      <table class="extras">
        <tbody>
          {site.extras.map((e) => (
            <tr>
              <td>{trExtra(e.id, lang)}</td>
              <td class="extras-price">{e.price.toFixed(2).replace('.', ',')} €</td>
              <td class="extras-unit">{trUnit(e.unit, lang)}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="muted-note">{t('apartments.priceNote')}</p>
      <p class="muted-note">{t('apartments.kurtaxeNote')}</p>
    </div>
  </section>

  <ThemeLinks lang={lang} />

  <Faq lang={lang} />
</BaseLayout>

<style>
  .page-head { padding-bottom: 1.5rem; }
  .apt-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }
  @media (max-width: 960px) { .apt-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .apt-grid { grid-template-columns: 1fr; } }
  .extras { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }
  .extras td { padding: 0.8rem 0.5rem; border-bottom: 1px solid var(--line); }
  .extras-price { font-weight: 700; color: var(--brand-strong); white-space: nowrap; }
  .extras-unit { color: var(--text-muted); text-align: right; }
  .muted-note { color: var(--text-muted); font-size: 0.9rem; margin-top: 1rem; }

  .apt-filter { display: flex; flex-wrap: wrap; gap: 0.8rem 1.6rem; align-items: center; justify-content: center; margin-bottom: 1.8rem; }
  .filter-group, .filter-toggles { display: inline-flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
  .filter-legend { color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; margin-right: 0.2rem; }
  .filter-pill {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--surface); border: 1px solid var(--line); border-radius: 999px;
    padding: 0.45rem 0.95rem; font: inherit; font-size: 0.9rem; font-weight: 600;
    color: var(--text); cursor: pointer; transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .filter-pill :global(svg) { flex: none; }
  .filter-pill:hover { border-color: var(--c-aqua-300); }
  .filter-pill.is-active { background: var(--brand); color: #fff; border-color: var(--brand); }
  .filter-none {
    display: block; margin: 1.5rem auto 0; padding: 0; background: none; border: 0;
    font: inherit; text-align: center; color: var(--text-muted); cursor: pointer;
    text-decoration: underline;
  }
  .filter-none[hidden] { display: none; }
  .theme-section { padding-block: clamp(2rem, 1.5rem + 2vw, 3rem); }
  .theme-links { display: flex; flex-wrap: wrap; gap: 0.7rem; justify-content: center; margin-top: 1rem; }
  .theme-links a {
    background: var(--surface); border: 1px solid var(--line); border-radius: 999px;
    padding: 0.5rem 1.1rem; text-decoration: none; font-weight: 600; color: var(--brand);
  }
  .theme-links a:hover { border-color: var(--c-aqua-300); color: var(--brand-strong); }
</style>

<script>
  const grid = document.querySelector('[data-apt-grid]');
  if (grid) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-apt]'));
    const none = document.querySelector<HTMLElement>('[data-filter-none]');
    const state: Record<string, number | boolean> = { persons: 0, dog: false, seaview: false };

    const apply = () => {
      let visible = 0;
      cards.forEach((c) => {
        const persons = Number(c.dataset.persons) || 0;
        const ok =
          persons >= (state.persons as number) &&
          (!state.dog || c.dataset.dog === '1') &&
          (!state.seaview || c.dataset.seaview === '1');
        c.style.display = ok ? '' : 'none';
        if (ok) visible++;
      });
      if (none) none.hidden = visible !== 0;
    };

    document.querySelectorAll<HTMLButtonElement>('[data-filter="persons"] .filter-pill').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-filter="persons"] .filter-pill').forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        state.persons = Number(btn.dataset.value) || 0;
        apply();
      });
    });
    document.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.toggle as string;
        state[key] = !state[key];
        btn.classList.toggle('is-active', state[key] as boolean);
        btn.setAttribute('aria-pressed', String(state[key]));
        apply();
      });
    });
    none?.addEventListener('click', () => {
      state.persons = 0; state.dog = false; state.seaview = false;
      document.querySelectorAll('.filter-pill').forEach((b) => {
        b.classList.remove('is-active');
        if (b.hasAttribute('aria-pressed')) b.setAttribute('aria-pressed', 'false');
      });
      document.querySelector('[data-filter="persons"] [data-value="0"]')?.classList.add('is-active');
      apply();
    });
  }
</script>
