---
import Icon from './Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from './CtaBanner.astro';
import ExperienceMap from './ExperienceMap.astro';
import { useTranslations, localizedPath, type Lang } from '../i18n/utils';
import { site } from '../data/site';
import { lageCards } from '../data/lage';
import { haversineKm, formatKm } from '../data/experiences';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const title = `${t('location.title')} · ${site.name} Büsum`;

const house = { name: site.name, coords: [site.geo.lat, site.geo.lng] as [number, number], address: `${site.address.street} · ${site.address.postalCode} ${site.address.city}` };

// Anreise-Inhalt aus lage.ts (die "atHome"-Karte).
const anreise = lageCards.find((c) => c.atHome)!;
const routeLink = anreise.activities[lang].find((a) => a.url)?.url;
const parkNote = anreise.activities[lang].find((a) => !a.url)?.name;

const L: Record<string, Record<Lang, string>> = {
  anreise: { de: 'Anreise & Parken', en: 'Getting here & parking', nl: 'Aankomst & parkeren', da: 'Ankomst & parkering' },
  route: { de: 'Route planen', en: 'Plan route', nl: 'Route plannen', da: 'Planlæg rute' },
  dist: { de: 'Entfernungen', en: 'Distances', nl: 'Afstanden', da: 'Afstande' },
};

// Orientierungspunkte (Karte + Entfernungsliste).
const orient: { name: Record<Lang, string>; icon: string; coords: [number, number] }[] = [
  { name: { de: 'Strand & Perlebucht', en: 'Beach & lagoon', nl: 'Strand & lagune', da: 'Strand & lagune' }, icon: '🏖️', coords: [54.1354887, 8.8394263] },
  { name: { de: 'Deich', en: 'Dyke', nl: 'Dijk', da: 'Dige' }, icon: '🐑', coords: [54.1392, 8.8430] },
  { name: { de: 'Wellenbad Meerzeit', en: 'Meerzeit wave pool', nl: 'Golfbad Meerzeit', da: 'Bølgebad Meerzeit' }, icon: '🌊', coords: [54.1281385, 8.8569203] },
  { name: { de: 'Ortszentrum', en: 'Town centre', nl: 'Centrum', da: 'Bymidte' }, icon: '🏘️', coords: [54.1294850, 8.8560528] },
  { name: { de: 'Hafen & Leuchtturm', en: 'Harbour & lighthouse', nl: 'Haven & vuurtoren', da: 'Havn & fyrtårn' }, icon: '⚓', coords: [54.1220931, 8.8588978] },
];
const orientPoints = orient.map((o) => ({ name: o.name[lang], icon: o.icon, coords: o.coords }));
---
<BaseLayout title={title} description={t('location.subtitle')} pageKey="lage">
  <section class="section lage-hero">
    <div class="container-narrow text-center">
      <p class="eyebrow">{t('site.tagline')}</p>
      <h1>{t('location.title')}</h1>
      <p class="lead mx-auto">{t('location.subtitle')}</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="lage-grid">
        <div class="lage-info">
          <h2>{L.anreise[lang]}</h2>
          <p class="anreise-text">{anreise.text[lang]}</p>
          {parkNote && <p class="park-note"><Icon name="check" size={15} /> {parkNote}</p>}
          <div class="lage-actions">
            {routeLink && <a class="btn btn--gold" href={routeLink} target="_blank" rel="noopener">{L.route[lang]}</a>}
            <a class="btn btn--ghost" href={localizedPath('apartments', lang)}>{t('apartments.all')}</a>
          </div>
          <h2 class="dist-h">{L.dist[lang]}</h2>
          <ul class="dist-list">
            {orient.map((o) => (
              <li>
                <span><span aria-hidden="true">{o.icon}</span> {o.name[lang]}</span>
                <strong>{formatKm(haversineKm(house.coords, o.coords), lang)}</strong>
              </li>
            ))}
          </ul>
        </div>
        <div class="lage-mapcol">
          <ExperienceMap lang={lang} home={house} points={orientPoints} showCards={false} mapId="lage-map" />
          <p class="text-center map-addr">{site.name} · {site.address.street} · {site.address.postalCode} {site.address.city}</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />
</BaseLayout>

<style>
  .lage-hero { padding-block: clamp(1.8rem, 1rem + 2.5vw, 3rem); }
  .anreise-text { max-width: 62ch; }
  .park-note { color: var(--brand); font-weight: 600; margin-top: 0.4rem; }
  .lage-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.2rem; }

  .lage-grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: 2.5rem; align-items: start; }
  @media (max-width: 900px) { .lage-grid { grid-template-columns: 1fr; gap: 1.6rem; } }
  .dist-h { margin-top: 1.8rem; }
  .lage-mapcol { position: sticky; top: 90px; }
  @media (max-width: 900px) { .lage-mapcol { position: static; } }

  .dist-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.1rem; }
  .dist-list li { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.7rem 0.2rem; border-bottom: 1px solid var(--line); }
  .dist-list strong { color: var(--brand-strong); white-space: nowrap; }
  .map-addr { color: var(--text-muted); margin-top: 0.8rem; }
</style>
