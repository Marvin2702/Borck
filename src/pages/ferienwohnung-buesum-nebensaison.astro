---
import { getCollection } from 'astro:content';
import ThemeLandingView from '../components/ThemeLandingView.astro';

const apartments = (await getCollection('apartments')).sort((a, b) => a.data.order - b.data.order);
---
<ThemeLandingView
  lang="de"
  pageKey="ferienwohnung-buesum-nebensaison"
  metaTitle="Ferienwohnung Büsum Nebensaison & Winter · Haus Aquamarin"
  metaDescription="Nordsee-Urlaub in der Nebensaison: ruhige Ferienwohnungen in Büsum für Herbst und Winter, ideal für längere Aufenthalte und mit Hund. Direkt buchen, ohne Buchungsgebühr."
  eyebrow="Nebensaison & Winter · Büsum"
  h1="Ferienwohnung in Büsum für die Nebensaison"
  intro={[
    "Die Nordsee außerhalb der Hauptsaison hat ihren eigenen Reiz: leere Strände, klare Luft und Ruhe. Die Apartments im Haus Aquamarin eignen sich besonders für längere Aufenthalte in Herbst und Winter – mit voll ausgestatteter Küche, WLAN und Hund.",
    "Stürmische Spaziergänge auf dem Deich, Wattwanderungen und gemütliche Abende: Sichern Sie sich Ihren Wunschzeitraum direkt im Buchungskalender, ohne Buchungsgebühr.",
  ]}
  apartments={apartments}
/>
